    volume = {68},
    copyright = {https://www.cambridge.org/core/terms},
    issn = {0031-8248, 1539-767X},
    shorttitle = {Refusing the {Devil}'s {Bargain}},
    url = {https://www.cambridge.org/core/product/identifier/S0031824800027987/type/journal_article},
    doi = {10.1086/392893},
    abstract = {Advocates have sought to
              prove
              that underdetermination obtains because all theories have
              empirical equivalents.
              But algorithms for generating empirical equivalents simply exchange underdetermination for familiar philosophical chestnuts, while the few convincing examples of empirical equivalents will not support the desired sweeping conclusions. Nonetheless, underdetermination does not depend on empirical equivalents: our warrant for current theories is equally undermined by presently unconceived alternatives as well-confirmed merely by the
              existing
              evidence, so long as this transient predicament recurs for each theory and body of evidence we consider. The historical record supports the claim that this recurrent, transient underdetermination predicament is our own.},
