{
  "engine": "SIMULATION_PACKAGE",
  "name": "My Insight",
  "simulation": {
    "version": "37",
    "time_length": "120",
    "time_start": "0",
    "time_step": "1",
    "time_units": "MONTHS",
    "algorithm": "RK4"
  },
  "elements": [
    {
      "name": "Learning_Rate",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.1",
        "description": "0.1",
        "units": "Unitless"
      }
    },
    {
      "name": "Idea_Generation_Rate",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.15",
        "description": "0.15",
        "units": "Unitless"
      }
    },
    {
      "name": "Market_Adoption_Rate",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.04",
        "description": "0.04",
        "units": "Unitless"
      }
    },
    {
      "name": "Competitive_Pressure",
      "type": "VARIABLE",
      "behavior": {
        "value": "(MAX(0, [Market_Position])/25)^0.5 + UNITLESS(Time/60) * 0.3",
        "description": "([Market Position]/100)^0.5\n\n(MAX(0, [Market Position])/100)^0.5",
        "units": "Unitless"
      }
    },
    {
      "name": "RD_Budget",
      "type": "VARIABLE",
      "behavior": {
        "value": "100",
        "description": "100",
        "units": "Unitless"
      }
    },
    {
      "name": "Psychological_Safety",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.7 + ([Leadership_Support] * 0.3)",
        "description": "0.7",
        "units": "Unitless"
      }
    },
    {
      "name": "Leadership_Support",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.9",
        "description": "0.8",
        "units": "Unitless"
      }
    },
    {
      "name": "Knowledge_Stock",
      "type": "STOCK",
      "behavior": {
        "initial_value": "100",
        "description": "100",
        "units": "Unitless"
      }
    },
    {
      "name": "Ideas_Pipeline",
      "type": "STOCK",
      "behavior": {
        "initial_value": "50",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Market_Position",
      "type": "STOCK",
      "behavior": {
        "initial_value": "20",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Human_Capital_Stock",
      "type": "STOCK",
      "behavior": {
        "initial_value": "50",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Technical_Infrastructure_Stock",
      "type": "STOCK",
      "behavior": {
        "initial_value": "40",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Org_Learning_Capability_Stock",
      "type": "STOCK",
      "behavior": {
        "initial_value": "30",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Innovation_Culture_Stock",
      "type": "STOCK",
      "behavior": {
        "initial_value": "25",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Institutional_Memory",
      "type": "STOCK",
      "behavior": {
        "initial_value": "30",
        "description": "30",
        "units": "Unitless"
      }
    },
    {
      "name": "Recovery_Capacity",
      "type": "VARIABLE",
      "behavior": {
        "value": "([Technical_Infrastructure_Stock] * [Institutional_Memory] * MAX(1.5, [Cultural_Energy]/20))/100",
        "description": "([Technical Infrastructure Stock] * [Institutional Memory]) / 100 \n  ([Technical Infrastructure Stock] * [Institutional Memory] * MAX(1, [Cultural Energy]/25))/100 ",
        "units": "Unitless"
      }
    },
    {
      "name": "Cultural_Energy",
      "type": "STOCK",
      "behavior": {
        "initial_value": "50",
        "description": "50",
        "units": "Unitless"
      }
    },
    {
      "name": "External_Shock",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.1 * (1 + PULSE(48))",
        "description": ".1",
        "units": "Unitless"
      }
    },
    {
      "name": "Renewal_Trigger",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Cultural_Energy] * 0.5 * MAX(0.2, MIN(1, ([Competitive_Pressure] + (50 - [Innovation_Culture_Stock])/50)/2))",
        "description": "MIN(1, MAX(0, (5 - [Innovation Culture Stock])/5) * MAX(0, ([Cultural Energy] - 50)/50)) \n  [Cultural Energy] * 0.5 * MAX(0, MIN(1, (5 - [Innovation Culture Stock]) * ([Cultural Energy] - 75)/100))  \n  [Cultural Energy] * 0.5 * MAX(0, MIN(1, (5 - [Innovation Culture Stock]) * PULSE(24)))\n\n[Cultural Energy] * 0.5 * MAX(0, UNITLESS(Time MOD 24)) ",
        "units": "Unitless"
      }
    },
    {
      "name": "Knowledge_Accumulation",
      "type": "FLOW",
      "from": null,
      "to": "Knowledge_Stock",
      "behavior": {
        "value": "[Learning_Rate] * MAX([Competitive_Pressure], 0.3) * 8 * MAX(0.6, MIN(1, ([Innovation_Culture_Stock] * [Org_Learning_Capability_Stock])/2000)) + 0.2",
        "description": "5 * MAX(0, 1 - [Cultural Energy]/100) \n   [Learning Rate] * [Competitive Pressure] *   (1 - [Knowledge Stock]/1000) * 5 *   ([Human Capital Stock]/100) *   ([Innovation Culture Stock]/50) *   ([Org Learning Capability Stock]/100)\n\n[Learning Rate] * [Competitive Pressure] * (1 - [Knowledge Stock]/1000) * 5 * MAX(0.5, MIN(1, ([Innovation Culture Stock] * [Org Learning Capability Stock])/5000)  ",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Knowledge_Flow",
      "type": "FLOW",
      "from": "Knowledge_Stock",
      "to": "Ideas_Pipeline",
      "behavior": {
        "value": "[Knowledge_Stock] * [Idea_Generation_Rate] * (1 + [Technical_Infrastructure_Stock]/100) *(1 + [Innovation_Culture_Stock]/100) * (0.5 + [Human_Capital_Stock]/200) * MAX(0.7, MIN(1.3, [Competitive_Pressure])) * (1 + [Institutional_Memory]/100) / 12",
        "description": "[Knowledge Stock]* [Idea Generation Rate]* (1 + [Technical Infrastructure Stock]/100) * (1 + [Innovation Culture Stock]/100) / 12",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Idea_Conversion",
      "type": "FLOW",
      "from": "Ideas_Pipeline",
      "to": "Market_Position",
      "behavior": {
        "value": "[Ideas_Pipeline] * [Market_Adoption_Rate] * MAX(0.3, MIN(1, (1 - ([Market_Position]/500)^2))) * (0.5 + ([Knowledge_Stock]/200) * 0.3) * MIN(1, ([Competitive_Pressure] * 2)^0.5) * (0.7 + ([Innovation_Culture_Stock] - [Competitive_Pressure])/50)",
        "description": "[Ideas Pipeline] * [Market Adoption Rate] * MAX(0, MIN(1, (1 - ([Market Position]/500)^2))) * 0.5",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Hiring_Rate",
      "type": "FLOW",
      "from": null,
      "to": "Human_Capital_Stock",
      "behavior": {
        "value": "[RD_Budget]* 0.3 * (1 - [Human_Capital_Stock]/200)",
        "description": "[RD Budget]* 0.3 * (1 - [Human Capital Stock]/200)",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Attrition_Rate",
      "type": "FLOW",
      "from": "Human_Capital_Stock",
      "to": null,
      "behavior": {
        "value": "[Human_Capital_Stock]* 0.1",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Infrastructure_Investment",
      "type": "FLOW",
      "from": null,
      "to": "Technical_Infrastructure_Stock",
      "behavior": {
        "value": "[RD_Budget] * 0.4 * (1 - [Technical_Infrastructure_Stock]/150) * MAX(0.5, MIN(1, [Innovation_Culture_Stock]/50)) * (0.7 + [Knowledge_Stock]/200) * MAX(0.8, MIN(1.2, [Market_Position]/100))",
        "description": "[RD Budget]* 0.4 * (1 - [Technical Infrastructure Stock]/150) \n  [RD Budget] * 0.4 * (1 - [Technical Infrastructure Stock]/150) * MAX(0.5, MIN(1, [Innovation Culture Stock]/50)) ",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Infrastructure_Decay",
      "type": "FLOW",
      "from": "Technical_Infrastructure_Stock",
      "to": null,
      "behavior": {
        "value": "[Technical_Infrastructure_Stock]* 0.15",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Learning_Investment",
      "type": "FLOW",
      "from": null,
      "to": "Org_Learning_Capability_Stock",
      "behavior": {
        "value": "[Leadership_Support] * (1 - [Org_Learning_Capability_Stock]/100) * 0.45 * (1 + [Innovation_Culture_Stock]/20)",
        "description": "[Leadership Support]* (1 - [Org Learning Capability Stock]/100) * 0.2 \n  ([Leadership Support] * (1 - [Org Learning Capability Stock]/100) * 0.45) + ([Innovation Culture Stock]/100 * 0.2)  \n  [Leadership Support] * (1 - [Org Learning Capability Stock]/100) * 0.35 * (1 + [Innovation Culture Stock]/25) ",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Learning_Decay",
      "type": "FLOW",
      "from": "Org_Learning_Capability_Stock",
      "to": null,
      "behavior": {
        "value": "MAX([Org_Learning_Capability_Stock] * 0.08, [Org_Learning_Capability_Stock] - 25)",
        "description": "[Org Learning Capability Stock]* 0.1",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Culture_Investment",
      "type": "FLOW",
      "from": null,
      "to": "Innovation_Culture_Stock",
      "behavior": {
        "value": "([Leadership_Support] * [Psychological_Safety] * (1 - [Innovation_Culture_Stock]/100) * 0.4 * MAX(1, [Cultural_Energy]/25)) + ([Org_Learning_Capability_Stock]/100 * 0.3) * (1 + PULSE(36))",
        "description": "[Leadership Support]* [Psychological Safety]* (1 - [Innovation Culture Stock]/100) * 0.15\n\n([Leadership Support] * [Psychological Safety] * (1 - [Innovation Culture Stock]/100) * 0.3 * [Cultural Energy]/50) + ([Org Learning Capability Stock]/100 * 0.2)\n\n([Leadership Support] * [Psychological Safety] * (1 - [Innovation Culture Stock]/100) * 0.3 * MAX(1, [Cultural Energy]/25)) + ([Org Learning Capability Stock]/100 * 0.2) * (1 + PULSE(36))",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Culture_Resistance",
      "type": "FLOW",
      "from": "Innovation_Culture_Stock",
      "to": null,
      "behavior": {
        "value": "MAX([Innovation_Culture_Stock] * 0.12, [Innovation_Culture_Stock] - 25)",
        "description": "[Innovation Culture Stock]* 0.2 \n  MAX([Innovation Culture Stock] * 0.15, [Innovation Culture Stock] - 20) ",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Practice_Codification",
      "type": "FLOW",
      "from": null,
      "to": "Institutional_Memory",
      "behavior": {
        "value": "([Knowledge_Stock] * [Technical_Infrastructure_Stock]/100) * 0.1",
        "description": "([Knowledge Stock] * [Technical Infrastructure Stock]/100) * 0.1",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Learning_Documentation",
      "type": "FLOW",
      "from": null,
      "to": "Institutional_Memory",
      "behavior": {
        "value": "[Org_Learning_Capability_Stock] * [Leadership_Support] * 0.2",
        "description": "[Org Learning Capability Stock] * [Leadership Support] * 0.2",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Memory_Decay",
      "type": "FLOW",
      "from": "Institutional_Memory",
      "to": null,
      "behavior": {
        "value": "[Institutional_Memory] * 0.1",
        "description": "[Institutional Memory] * 0.1",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Practice_Obsolescence",
      "type": "FLOW",
      "from": "Institutional_Memory",
      "to": null,
      "behavior": {
        "value": "[Institutional_Memory] * ([Competitive_Pressure] * 0.2)",
        "description": "[Institutional Memory] * ([Competitive Pressure] * 0.2)",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Energy_Expenditure",
      "type": "FLOW",
      "from": "Cultural_Energy",
      "to": null,
      "behavior": {
        "value": "MIN([Cultural_Energy], MAX(0, [Cultural_Energy] * 0.3 * [Renewal_Trigger]))",
        "description": "[Cultural Energy] * 0.3 * [Renewal Trigger]",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Natural_Energy_Decay",
      "type": "FLOW",
      "from": "Cultural_Energy",
      "to": null,
      "behavior": {
        "value": "[Cultural_Energy] * 0.03",
        "description": "[Cultural Energy] * 0.05",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Crisis_Response",
      "type": "FLOW",
      "from": null,
      "to": "Cultural_Energy",
      "behavior": {
        "value": "10 * [External_Shock]",
        "description": "10 * [External Shock]",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Energy_Accumulation",
      "type": "FLOW",
      "from": null,
      "to": "Cultural_Energy",
      "behavior": {
        "value": "5 * MAX(0, (10 - [Innovation_Culture_Stock])/10) * (1 - [Cultural_Energy]/100) * MAX(0, UNITLESS(Time MOD 24))",
        "description": "2 * MAX(0, (10 - [Innovation Culture Stock])/10) * (1 - [Cultural Energy]/100)\n\n5 * MAX(0, (10 - [Innovation Culture Stock])/10) * (1 - [Cultural Energy]/100) * (Time/{1200 MONTHS})\n\n5 * MAX(0, (10 - [Innovation Culture Stock])/10) * (1 - [Cultural Energy]/100) * PULSE(24)\n\n5 * MAX(0, (10 - [Innovation Culture Stock])/10) * (1 - [Cultural Energy]/100) * MAX(0, UNITLESS(Time MOD 24))",
        "units": "Unitless",
        "non_negative": true
      }
    },
