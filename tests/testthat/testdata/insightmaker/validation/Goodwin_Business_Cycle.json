{
  "engine": "SIMULATION_PACKAGE",
  "name": "Goodwin Business Cycle",
  "simulation": {
    "version": "36",
    "time_length": "100",
    "time_start": "0",
    "time_step": "0.5",
    "time_units": "YEARS",
    "algorithm": "RK1"
  },
  "elements": [
    {
      "name": "Capital",
      "type": "STOCK",
      "behavior": {
        "initial_value": "300",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "investment",
      "type": "FLOW",
      "from": null,
      "to": "Capital",
      "behavior": {
        "value": "[Profit]*[fraction_invested]",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "fraction_invested",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.99",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Wage_share",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Wages]/[Output]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Output",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Capital]/[accelerator]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Profit",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Output]-[Wages]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "accelerator",
      "type": "VARIABLE",
      "behavior": {
        "value": "3",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Employment",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Output]/[Productivity]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Wages",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Wage_rate]*[Employment]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Employment_rate",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Employment]/([Working_population]*[Participation_rate])",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Working_population",
      "type": "STOCK",
      "behavior": {
        "initial_value": "110",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "pop_increase",
      "type": "FLOW",
      "from": null,
      "to": "Working_population",
      "behavior": {
        "value": "[Working_population]*[growth_rate]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "growth_rate",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.02",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Participation_rate",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.9",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Wage_change",
      "type": "CONVERTER",
      "behavior": {
        "input": "ELEMENT",
        "input_element": "Employment_rate",
        "interpolation": "LINEAR",
        "data": [
            [0.78, -0.04],
            [0.797, -0.02],
            [0.815, -0.035],
            [0.832, -0.035],
            [0.85, -0.0313],
            [0.867, -0.0163],
            [0.885, 0.0025],
            [0.902, 0.0212],
            [0.92, 0.0362],
            [0.937, 0.0587],
            [0.955, 0.0737],
            [0.972, 0.085],
            [0.99, 0.0962]
          ],
        "units": "Unitless"
      }
    },
    {
      "name": "Wage_rate",
      "type": "STOCK",
      "behavior": {
        "initial_value": "1",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "wage_increase",
      "type": "FLOW",
      "from": null,
      "to": "Wage_rate",
      "behavior": {
        "value": "[Wage_rate]*[Wage_change]",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Productivity",
      "type": "STOCK",
      "behavior": {
        "initial_value": "1",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "productivity_increase",
      "type": "FLOW",
      "from": null,
      "to": "Productivity",
      "behavior": {
        "value": "[Productivity]*[productivity_growth_rate]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "productivity_growth_rate",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.01",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "type": "LINK",
      "from": "fraction_invested",
      "to": "investment"
    },
    {
      "type": "LINK",
      "from": "Profit",
      "to": "investment"
    },
    {
      "type": "LINK",
      "from": "Capital",
      "to": "investment"
    },
    {
      "type": "LINK",
      "from": "Output",
      "to": "Wage_share"
    },
    {
      "type": "LINK",
      "from": "Wages",
      "to": "Wage_share"
    },
    {
      "type": "LINK",
      "from": "Capital",
      "to": "Output"
    },
    {
      "type": "LINK",
      "from": "accelerator",
      "to": "Output"
    },
    {
      "type": "LINK",
      "from": "Output",
      "to": "Profit"
    },
    {
      "type": "LINK",
      "from": "Wages",
      "to": "Profit"
    },
    {
      "type": "LINK",
      "from": "Output",
      "to": "Employment"
    },
    {
      "type": "LINK",
      "from": "Productivity",
      "to": "Employment"
    },
    {
      "type": "LINK",
      "from": "Employment",
      "to": "Wages"
    },
    {
      "type": "LINK",
      "from": "Wage_rate",
      "to": "Wages"
    },
    {
      "type": "LINK",
      "from": "Employment",
      "to": "Employment_rate"
    },
    {
      "type": "LINK",
      "from": "Working_population",
      "to": "Employment_rate"
    },
    {
      "type": "LINK",
      "from": "Participation_rate",
      "to": "Employment_rate"
    },
    {
      "type": "LINK",
      "from": "Working_population",
      "to": "pop_increase"
    },
    {
      "type": "LINK",
      "from": "growth_rate",
      "to": "pop_increase"
    },
    {
      "type": "LINK",
      "from": "Working_population",
      "to": "pop_increase"
    },
    {
      "type": "LINK",
      "from": "Wage_change",
      "to": "wage_increase"
    },
    {
      "type": "LINK",
      "from": "Wage_rate",
      "to": "wage_increase"
    },
    {
      "type": "LINK",
      "from": "Wage_rate",
      "to": "wage_increase"
    },
    {
      "type": "LINK",
      "from": "Productivity",
      "to": "productivity_increase"
    },
    {
      "type": "LINK",
      "from": "productivity_growth_rate",
