{
  "engine": "SIMULATION_PACKAGE",
  "name": "Tragedy of the Commons",
  "simulation": {
    "version": "38",
    "time_length": "20",
    "time_start": "0",
    "time_step": "0.5",
    "time_units": "WEEKS",
    "algorithm": "RK1"
  },
  "elements": [
    {
      "name": "a_result",
      "type": "STOCK",
      "behavior": {
        "initial_value": "1",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "b_result",
      "type": "STOCK",
      "behavior": {
        "initial_value": "2",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "resources_available",
      "type": "STOCK",
      "behavior": {
        "initial_value": "50",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "a_activity",
      "type": "FLOW",
      "from": "resources_available",
      "to": "a_result",
      "behavior": {
        "value": "IfThenElse([a_factor]*[a_result] < .5 * ([resources_available]-[min_res]), [a_factor]*[a_result], .5 * ([resources_available]-[min_res]))",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "b_activity",
      "type": "FLOW",
      "from": "resources_available",
      "to": "b_result",
      "behavior": {
        "value": "IfThenElse([b_factor]*[b_result] < .5 * ([resources_available]-[min_res]), [b_factor]*[b_result], .5 * ([resources_available]-[min_res]))",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "a_factor",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.3",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "b_factor",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.2",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "resource_repenishment",
      "type": "FLOW",
      "from": null,
      "to": "resources_available",
      "behavior": {
        "value": "[replenishment_rate]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "replenishment_rate",
      "type": "VARIABLE",
      "behavior": {
        "value": "5",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "min_res",
      "type": "VARIABLE",
      "behavior": {
        "value": "0",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "a_activity_",
      "type": "VARIABLE",
      "behavior": {
        "value": "0",
        "description": "a's activity which adds to it's own results.",
        "units": "Unitless"
      }
    },
    {
      "name": "a_results_",
      "type": "VARIABLE",
      "behavior": {
        "value": "0",
        "description": "a's results from its own activity in conjunction with the common resources it consumes.",
        "units": "Unitless"
      }
    },
    {
      "name": "b_activity_",
      "type": "VARIABLE",
      "behavior": {
        "value": "0",
        "description": "b's activity toward the development of its own results.",
        "units": "Unitless"
      }
    },
    {
      "name": "b_results_",
      "type": "VARIABLE",
      "behavior": {
        "value": "0",
        "description": "The results b produces from its activity in conjunction with the resources available.",
        "units": "Unitless"
      }
    },
    {
      "name": "total_activity",
      "type": "VARIABLE",
      "behavior": {
        "value": "0",
        "description": "The sum of the activity of a and b.",
        "units": "Unitless"
      }
    },
    {
      "name": "resources_available_",
      "type": "VARIABLE",
      "behavior": {
        "value": "0",
        "description": "Resources available for a and b to use which are also diminished by that activity.",
        "units": "Unitless"
      }
    },
    {
      "name": "resource_limit",
      "type": "VARIABLE",
      "behavior": {
        "value": "0",
        "description": "The limit of the resources available. As long as the total activity is less than this level neither a nor b perceives there to be a resource limit.",
        "units": "Unitless"
      }
    },
    {
      "type": "LINK",
      "from": "a_result",
      "to": "a_activity"
    },
    {
      "type": "LINK",
      "from": "a_result",
      "to": "a_activity"
    },
    {
      "type": "LINK",
      "from": "resources_available",
      "to": "a_activity"
    },
    {
      "type": "LINK",
      "from": "resources_available",
      "to": "a_activity"
    },
    {
      "type": "LINK",
      "from": "a_factor",
      "to": "a_activity"
    },
    {
      "type": "LINK",
      "from": "a_factor",
      "to": "a_activity"
    },
    {
      "type": "LINK",
      "from": "min_res",
      "to": "a_activity"
    },
    {
      "type": "LINK",
      "from": "min_res",
      "to": "a_activity"
    },
    {
      "type": "LINK",
      "from": "resources_available",
      "to": "a_activity"
    },
    {
      "type": "LINK",
      "from": "a_result",
      "to": "a_activity"
    },
    {
      "type": "LINK",
      "from": "b_result",
      "to": "b_activity"
    },
    {
      "type": "LINK",
      "from": "b_result",
      "to": "b_activity"
    },
    {
      "type": "LINK",
      "from": "resources_available",
      "to": "b_activity"
    },
    {
      "type": "LINK",
      "from": "resources_available",
      "to": "b_activity"
    },
    {
      "type": "LINK",
      "from": "b_factor",
      "to": "b_activity"
    },
    {
      "type": "LINK",
      "from": "b_factor",
      "to": "b_activity"
    },
    {
      "type": "LINK",
      "from": "min_res",
      "to": "b_activity"
    },
    {
      "type": "LINK",
      "from": "min_res",
      "to": "b_activity"
    },
    {
      "type": "LINK",
      "from": "resources_available",
      "to": "b_activity"
    },
    {
      "type": "LINK",
      "from": "b_result",
      "to": "b_activity"
    },
    {
      "type": "LINK",
      "from": "replenishment_rate",
      "to": "resource_repenishment"
    },
    {
      "type": "LINK",
      "from": "resources_available",
      "to": "resource_repenishment"
    }
  ],
  "engine_settings": []
}
