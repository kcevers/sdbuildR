{
  "engine": "SIMULATION_PACKAGE",
  "name": "Outpatient Clinics Patient Flow",
  "simulation": {
    "version": "36",
    "time_length": "250",
    "time_start": "0",
    "time_step": "1",
    "time_units": "DAYS",
    "algorithm": "RK1"
  },
  "elements": [
    {
      "name": "FSA_waiting_list",
      "type": "STOCK",
      "behavior": {
        "initial_value": "1400",
        "description": "There are 1400 patients on current waiting list.",
        "units": "Unitless"
      }
    },
    {
      "name": "population_grow_percentage",
      "type": "VARIABLE",
      "behavior": {
        "value": "0",
        "description": "It assumes there is no population grow. However, population in Counties Manukau Health area are growing 2-3% annually. \n",
        "units": "Unitless"
      }
    },
    {
      "name": "FSA_referrals_daily",
      "type": "VARIABLE",
      "behavior": {
        "value": "30",
        "description": "On average, it's about 26.85 FSA referrals a day. In the past, it was vary from 23-27. \n",
        "units": "Unitless"
      }
    },
    {
      "name": "Followups",
      "type": "STOCK",
      "behavior": {
        "initial_value": "49",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "FSA_to_community",
      "type": "FLOW",
      "from": "FSA",
      "to": null,
      "behavior": {
        "value": "[FSA_capacity]*[FSA_to_community_percentage]/100",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "FSA_to_other",
      "type": "FLOW",
      "from": "FSA",
      "to": null,
      "behavior": {
        "value": "[FSA_capacity]*[FSA_to_other_percentage]/100",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "FSA_to_community_percentage",
      "type": "VARIABLE",
      "behavior": {
        "value": "100-[FSA_to_followups_percentage]-[FSA_to_other_percentage]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "FSA_to_followups_percentage",
      "type": "VARIABLE",
      "behavior": {
        "value": "36",
        "description": "Current 36%",
        "units": "Unitless"
      }
    },
    {
      "name": "FSA_capacity",
      "type": "VARIABLE",
      "behavior": {
        "value": "IfThenElse([followups_to_followups]>[followups_to_followups_current],[Outpatient_clinics_capacity_control]-([followups_to_followups]-[followups_to_followups_current]),[Outpatient_clinics_capacity_control]+([followups_to_followups_current]-[followups_to_followups])/2)",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "followups_to_followups_percentage",
      "type": "VARIABLE",
      "behavior": {
        "value": "50",
        "description": "Currently, 50% of discharged patients require followups.\n",
        "units": "Unitless"
      }
    },
    {
      "name": "followups_to_followups_current",
      "type": "VARIABLE",
      "behavior": {
        "value": "24.5",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Average_waiting_days",
      "type": "VARIABLE",
      "behavior": {
        "value": "[FSA_waiting_list]/[FSA_waiting_list_to_FSA]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Outpatient_clinics_total_capacity",
      "type": "VARIABLE",
      "behavior": {
        "value": "[FSA_waiting_list_to_FSA]+[followups_dishcarging]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "FSA_to_other_percentage",
      "type": "VARIABLE",
      "behavior": {
        "value": "29",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "FSA",
      "type": "STOCK",
      "behavior": {
        "initial_value": "27",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "FSA_waiting_list_to_FSA",
      "type": "FLOW",
      "from": "FSA_waiting_list",
      "to": "FSA",
      "behavior": {
        "value": "[FSA_to_followups]/[FSA_to_followups_percentage]*100",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "followups_dishcarging",
      "type": "FLOW",
      "from": "Followups",
      "to": null,
      "behavior": {
        "value": "[Followups]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "FSA_waiting_list_referrals",
      "type": "FLOW",
      "from": null,
      "to": "FSA_waiting_list",
      "behavior": {
        "value": "[FSA_referrals_daily]*(100+[population_grow_percentage])/100",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "followups_from_other",
      "type": "FLOW",
      "from": null,
      "to": "Followups",
      "behavior": {
        "value": "15",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "followups_to_followups",
      "type": "FLOW",
      "from": null,
      "to": "Followups",
      "behavior": {
        "value": "[followups_dishcarging]*[followups_to_followups_percentage]/100",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "FSA_to_followups",
      "type": "FLOW",
      "from": "FSA",
      "to": "Followups",
      "behavior": {
        "value": "[FSA_capacity]*[FSA_to_followups_percentage]/100",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Outpatient_clinics_capacity_control",
      "type": "VARIABLE",
      "behavior": {
        "value": "3",
        "description": "\n",
        "units": "Unitless"
      }
    },
    {
      "type": "LINK",
      "from": "FSA_to_community_percentage",
      "to": "FSA_to_community"
    },
    {
      "type": "LINK",
      "from": "FSA_capacity",
      "to": "FSA_to_community"
    },
    {
      "type": "LINK",
      "from": "FSA",
      "to": "FSA_to_community"
    },
    {
      "type": "LINK",
      "from": "FSA_capacity",
      "to": "FSA_to_other"
    },
    {
      "type": "LINK",
      "from": "FSA_to_other_percentage",
      "to": "FSA_to_other"
    },
    {
      "type": "LINK",
      "from": "FSA",
      "to": "FSA_to_other"
    },
    {
      "type": "LINK",
      "from": "FSA_to_followups_percentage",
      "to": "FSA_to_community_percentage"
    },
    {
      "type": "LINK",
      "from": "FSA_to_other_percentage",
      "to": "FSA_to_community_percentage"
    },
    {
      "type": "LINK",
      "from": "followups_to_followups_current",
      "to": "FSA_capacity"
    },
    {
      "type": "LINK",
      "from": "followups_to_followups_current",
      "to": "FSA_capacity"
    },
    {
      "type": "LINK",
      "from": "followups_to_followups_current",
      "to": "FSA_capacity"
    },
    {
      "type": "LINK",
      "from": "followups_to_followups",
      "to": "FSA_capacity"
    },
    {
      "type": "LINK",
      "from": "followups_to_followups",
      "to": "FSA_capacity"
    },
    {
      "type": "LINK",
      "from": "followups_to_followups",
      "to": "FSA_capacity"
    },
    {
      "type": "LINK",
      "from": "Outpatient_clinics_capacity_control",
      "to": "FSA_capacity"
    },
    {
      "type": "LINK",
      "from": "Outpatient_clinics_capacity_control",
      "to": "FSA_capacity"
    },
    {
      "type": "LINK",
      "from": "FSA_waiting_list",
      "to": "Average_waiting_days"
    },
    {
      "type": "LINK",
      "from": "FSA_waiting_list_to_FSA",
      "to": "Average_waiting_days"
    },
    {
      "type": "LINK",
      "from": "FSA_waiting_list_to_FSA",
      "to": "Outpatient_clinics_total_capacity"
    },
    {
      "type": "LINK",
      "from": "followups_dishcarging",
      "to": "Outpatient_clinics_total_capacity"
    },
    {
      "type": "LINK",
      "from": "FSA_to_followups_percentage",
      "to": "FSA_waiting_list_to_FSA"
    },
    {
      "type": "LINK",
      "from": "FSA_to_followups",
      "to": "FSA_waiting_list_to_FSA"
    },
    {
      "type": "LINK",
      "from": "FSA_waiting_list",
      "to": "FSA_waiting_list_to_FSA"
    },
    {
      "type": "LINK",
      "from": "FSA",
      "to": "FSA_waiting_list_to_FSA"
    },
    {
      "type": "LINK",
      "from": "Followups",
      "to": "followups_dishcarging"
    },
    {
      "type": "LINK",
      "from": "Followups",
      "to": "followups_dishcarging"
    },
    {
      "type": "LINK",
      "from": "population_grow_percentage",
      "to": "FSA_waiting_list_referrals"
    },
    {
      "type": "LINK",
      "from": "FSA_referrals_daily",
      "to": "FSA_waiting_list_referrals"
    },
    {
      "type": "LINK",
      "from": "FSA_waiting_list",
      "to": "FSA_waiting_list_referrals"
    },
    {
      "type": "LINK",
      "from": "Followups",
      "to": "followups_from_other"
    },
    {
      "type": "LINK",
      "from": "followups_to_followups_percentage",
      "to": "followups_to_followups"
    },
    {
      "type": "LINK",
      "from": "followups_dishcarging",
      "to": "followups_to_followups"
    },
    {
      "type": "LINK",
      "from": "Followups",
      "to": "followups_to_followups"
    },
    {
      "type": "LINK",
      "from": "FSA_to_followups_percentage",
      "to": "FSA_to_followups"
    },
    {
      "type": "LINK",
      "from": "FSA_capacity",
      "to": "FSA_to_followups"
    },
    {
      "type": "LINK",
      "from": "FSA",
      "to": "FSA_to_followups"
    },
    {
      "type": "LINK",
      "from": "Followups",
      "to": "FSA_to_followups"
    }
  ],
  "engine_settings": []
}
