{
  "engine": "SIMULATION_PACKAGE",
  "name": "Global Climate Change",
  "simulation": {
    "version": "38",
    "time_length": "140",
    "time_start": "1960",
    "time_step": "1",
    "time_units": "YEARS",
    "algorithm": "RK1"
  },
  "elements": [
    {
      "name": "Earth_Energy",
      "type": "STOCK",
      "behavior": {
        "initial_value": "[e0] * scaledJoules",
        "description": "",
        "units": "Joules"
      }
    },
    {
      "name": "Solar_Radiation",
      "type": "FLOW",
      "from": null,
      "to": "Earth_Energy",
      "behavior": {
        "value": "SolarFlux * pi * EarthRadius^2",
        "description": "Solar radiation, does not interact with the atmosphere.",
        "units": "Watts",
        "non_negative": true
      }
    },
    {
      "name": "Atmospheric_Energy",
      "type": "STOCK",
      "behavior": {
        "initial_value": "[e0] * scaledJoules",
        "description": "",
        "units": "Joules"
      }
    },
    {
      "name": "Radiation_Down",
      "type": "FLOW",
      "from": "Atmospheric_Energy",
      "to": "Earth_Energy",
      "behavior": {
        "value": "[Atmosphere_Radiation] / 2",
        "description": "",
        "units": "Watts",
        "non_negative": true
      }
    },
    {
      "name": "Pass_Through",
      "type": "FLOW",
      "from": "Atmospheric_Energy",
      "to": null,
      "behavior": {
        "value": "[Atmospheric_Energy] * [Emissivity] * scaledWatts",
        "description": "",
        "units": "Watts",
        "non_negative": true
      }
    },
    {
      "name": "Atmospheric_Carbon_Dioxide",
      "type": "STOCK",
      "behavior": {
        "initial_value": "[Historical_CO2_PPM] * CO2MassToPPM",
        "description": "",
        "units": "Tons CO2"
      }
    },
    {
      "name": "Global_Temperature",
      "type": "VARIABLE",
      "behavior": {
        "value": "KelvinToCelsius([Absolute_Temperature])",
        "description": "",
        "units": "Degrees Celsius"
      }
    },
    {
      "name": "Reflection",
      "type": "FLOW",
      "from": "Earth_Energy",
      "to": null,
      "behavior": {
        "value": "[Solar_Radiation] * [Earth_Albedo]",
        "description": "Solar radiation reflect by the earth (or atmosphere). The atmosphere does not interact with it.",
        "units": "Watts",
        "non_negative": true
      }
    },
    {
      "name": "Radiation",
      "type": "FLOW",
      "from": "Earth_Energy",
      "to": "Atmospheric_Energy",
      "behavior": {
        "value": "[Earth_Energy] * scaledWatts",
        "description": "",
        "units": "Watts",
        "non_negative": true
      }
    },
    {
      "name": "Absolute_Temperature",
      "type": "VARIABLE",
      "behavior": {
        "value": "([Radiation] / (Boltzmann * (EarthRadius^2 * pi * 4)))^ (1/4)",
        "description": "",
        "units": "Degrees Kelvin"
      }
    },
    {
      "name": "Radiation_Up",
      "type": "FLOW",
      "from": "Atmospheric_Energy",
      "to": null,
      "behavior": {
        "value": "[Atmosphere_Radiation] / 2",
        "description": "",
        "units": "Watts",
        "non_negative": true
      }
    },
    {
      "name": "Emissivity",
      "type": "CONVERTER",
      "behavior": {
        "input": "ELEMENT",
        "input_element": "CO2_PPM",
        "interpolation": "LINEAR",
        "data": [
            [200, 0.194],
            [400, 0.14],
            [600, 0.108],
            [800, 0.085],
            [1600, 0.0301]
          ],
        "units": "Unitless"
      }
    },
    {
      "name": "CO2_PPM",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Atmospheric_Carbon_Dioxide] / CO2MassToPPM",
        "description": "",
        "units": "PPM CO2"
      }
    },
    {
      "name": "Atmosphere_Radiation",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Atmospheric_Energy] * (1 - [Emissivity]) * scaledWatts",
        "description": "",
        "units": "Watts"
      }
    },
