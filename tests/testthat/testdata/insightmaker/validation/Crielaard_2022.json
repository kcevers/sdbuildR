{
  "engine": "SIMULATION_PACKAGE",
  "name": "Crielaard et al. (2022)",
  "simulation": {
    "version": "38",
    "time_length": "250",
    "time_start": "0",
    "time_step": "0.01",
    "time_units": "DAYS",
    "algorithm": "RK4"
  },
  "elements": [
    {
      "name": "Hunger",
      "type": "STOCK",
      "behavior": {
        "initial_value": "Rand()",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Eating",
      "type": "STOCK",
      "behavior": {
        "initial_value": "Rand()",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Compensatory_behaviour",
      "type": "STOCK",
      "behavior": {
        "initial_value": "Rand()",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Losing_energy_by_compensatory_behavior",
      "type": "FLOW",
      "from": null,
      "to": "Hunger",
      "behavior": {
        "value": "(0.3*[Compensatory_behaviour])*((1-[Hunger])/1)",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Feeling_hunger",
      "type": "FLOW",
      "from": null,
      "to": "Eating",
      "behavior": {
        "value": "((0.8*[Hunger]^[a0])*[Eating])*((1-[Eating])/1)",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Satiety",
      "type": "FLOW",
      "from": "Eating",
      "to": null,
      "behavior": {
        "value": "(1.3 * ([Eating]))*((1-[Eating])/1)",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Eating_reduces_hunger",
      "type": "FLOW",
      "from": "Hunger",
      "to": null,
      "behavior": {
        "value": "((1.4*[Eating]^[a0])*[Hunger])*((1-[Hunger])/1)",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Compensating_for_having_eaten",
      "type": "FLOW",
      "from": null,
      "to": "Compensatory_behaviour",
      "behavior": {
        "value": "(Sig([a2]*[Eating]))*((1-[Compensatory_behaviour])/1)",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Satisfaction_with_hungry_feeling",
      "type": "FLOW",
      "from": "Compensatory_behaviour",
      "to": null,
      "behavior": {
        "value": "(1.3*[Hunger]*[Compensatory_behaviour])*((1-[Compensatory_behaviour])/1)",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "a0",
      "type": "VARIABLE",
      "behavior": {
        "value": "1.31",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "a2",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.38",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Effect_of_eating_triggers",
      "type": "FLOW",
      "from": null,
      "to": "Eating",
      "behavior": {
        "value": "([a1]*[Eating])*((1-[Eating])/1)",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Effect_of_compensatory_behavior",
      "type": "FLOW",
      "from": "Eating",
      "to": null,
      "behavior": {
        "value": "(2*[Compensatory_behaviour]*[Eating])*((1-[Eating])/1)",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "a1",
      "type": "VARIABLE",
      "behavior": {
        "value": "1.5",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "type": "LINK",
      "from": "Hunger",
      "to": "Losing_energy_by_compensatory_behavior"
    },
