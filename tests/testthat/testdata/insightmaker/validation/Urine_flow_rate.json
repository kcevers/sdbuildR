{
  "engine": "SIMULATION_PACKAGE",
  "name": "Urine flow rate",
  "simulation": {
    "version": "37",
    "time_length": "40",
    "time_start": "0",
    "time_step": "0.1",
    "time_units": "SECONDS",
    "algorithm": "RK4"
  },
  "elements": [
    {
      "name": "Volume",
      "type": "STOCK",
      "behavior": {
        "initial_value": "[V0]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "V0",
      "type": "VARIABLE",
      "behavior": {
        "value": "[V0_ml]/1000000",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "V0_ml",
      "type": "VARIABLE",
      "behavior": {
        "value": "300",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "CV",
      "type": "VARIABLE",
      "behavior": {
        "value": "2e-7",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Pressure",
      "type": "VARIABLE",
      "behavior": {
        "value": "[p_Det]+[Volume]/[CV]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "IV",
      "type": "FLOW",
      "from": "Volume",
      "to": null,
      "behavior": {
        "value": "if [Volume]>0 then\n  sqrt([Pressure]/[k])\nelse \n  0\nend if",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Density",
      "type": "VARIABLE",
      "behavior": {
        "value": "1000",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Cross_Section",
      "type": "VARIABLE",
      "behavior": {
        "value": "if Seconds()<5 then\n  0.00000000001+[A0]*Seconds()/5\nelse \n  [A0]\nend if",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "A0",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.00003",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "k",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Density]/([Cross_Section]^2)",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "P_torr",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Pressure]/133.3",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "IV_ml_s",
      "type": "VARIABLE",
      "behavior": {
        "value": "[IV]*1000000",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "p_Det",
      "type": "VARIABLE",
      "behavior": {
        "value": "600",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "type": "LINK",
      "from": "V0",
      "to": "Volume"
    },
    {
      "type": "LINK",
      "from": "V0_ml",
      "to": "V0"
    },
    {
      "type": "LINK",
      "from": "Volume",
      "to": "Pressure"
    },
    {
      "type": "LINK",
      "from": "CV",
      "to": "Pressure"
    },
    {
      "type": "LINK",
      "from": "p_Det",
      "to": "Pressure"
    },
    {
      "type": "LINK",
      "from": "Volume",
      "to": "IV"
    },
    {
      "type": "LINK",
      "from": "Pressure",
      "to": "IV"
    },
    {
      "type": "LINK",
      "from": "k",
      "to": "IV"
    },
    {
      "type": "LINK",
      "from": "Volume",
      "to": "IV"
    },
    {
      "type": "LINK",
      "from": "A0",
      "to": "Cross_Section"
    },
    {
      "type": "LINK",
      "from": "A0",
      "to": "Cross_Section"
    },
    {
      "type": "LINK",
      "from": "Density",
      "to": "k"
    },
    {
      "type": "LINK",
      "from": "Cross_Section",
      "to": "k"
    },
    {
      "type": "LINK",
      "from": "Pressure",
      "to": "P_torr"
    },
    {
      "type": "LINK",
      "from": "IV",
      "to": "IV_ml_s"
    }
  ],
  "engine_settings": []
}
