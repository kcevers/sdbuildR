{
  "engine": "SIMULATION_PACKAGE",
  "name": "Balancing an Inverted Pendulum",
  "simulation": {
    "version": "36",
    "time_length": "10",
    "time_start": "0",
    "time_step": "0.01",
    "time_units": "SECONDS",
    "algorithm": "RK1"
  },
  "elements": [
    {
      "name": "angular_velocity",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "velocity",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "change_of_velocity",
      "type": "FLOW",
      "from": null,
      "to": "velocity",
      "behavior": {
        "value": "[c]*[angle]+[d]*([control_function]+[perturbation])",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "angle",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0.2",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "position",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "control_work",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "change_of_angle",
      "type": "FLOW",
      "from": null,
      "to": "angle",
      "behavior": {
        "value": "[angular_velocity]",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "change_of_position",
      "type": "FLOW",
      "from": null,
      "to": "position",
      "behavior": {
        "value": "[velocity]",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "control_power",
      "type": "FLOW",
      "from": null,
      "to": "control_work",
      "behavior": {
        "value": "Abs([control_function]*[velocity])",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "d",
      "type": "VARIABLE",
      "behavior": {
        "value": "([moment_of_inertia_for_sphere]+[pendulum_mass]*[pendulum_length]^2)/[aa]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "a",
      "type": "VARIABLE",
      "behavior": {
        "value": "[gravitation_constant]*([pendulum_mass]+[carriage_mass])*[pendulum_mass]*[pendulum_length]/[aa]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "aa",
      "type": "VARIABLE",
      "behavior": {
        "value": "[moment_of_inertia_for_sphere]*([pendulum_mass]+[carriage_mass])+[pendulum_mass]*[carriage_mass]*[pendulum_length]^2",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "c",
      "type": "VARIABLE",
      "behavior": {
        "value": "-[gravitation_constant]*[pendulum_mass]^2*[pendulum_length]^2/[aa]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "b",
      "type": "VARIABLE",
      "behavior": {
        "value": "-[pendulum_mass]*[pendulum_length]/[aa]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "perturbation",
      "type": "VARIABLE",
      "behavior": {
        "value": "[amplitude]*(2*Rand(0,1)-1)",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "control_function",
      "type": "VARIABLE",
      "behavior": {
        "value": "[angle_feedback]*[angle]+[angular_velocity_feedback]*[angular_velocity]+[position_feedback]*[position]+[velocity_feedback]*[velocity]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "amplitude",
      "type": "VARIABLE",
      "behavior": {
        "value": "2",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "change_of_angular_velocity",
      "type": "FLOW",
      "from": null,
      "to": "angular_velocity",
      "behavior": {
        "value": "[a]*[angle]+[b]*([control_function]+[perturbation])",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "angle_feedback",
      "type": "VARIABLE",
      "behavior": {
        "value": "100",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "angular_velocity_feedback",
      "type": "VARIABLE",
      "behavior": {
        "value": "30",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "position_feedback",
      "type": "VARIABLE",
      "behavior": {
        "value": "3",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "velocity_feedback",
      "type": "VARIABLE",
      "behavior": {
        "value": "10",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "gravitation_constant",
      "type": "VARIABLE",
      "behavior": {
        "value": "9.81",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "carriage_mass",
      "type": "VARIABLE",
      "behavior": {
        "value": "1",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "pendulum_mass",
      "type": "VARIABLE",
      "behavior": {
        "value": "1",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "moment_of_inertia_for_sphere",
      "type": "VARIABLE",
      "behavior": {
        "value": "2*[pendulum_mass]*[radius_of_pendulum_mass]^2/5",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "pendulum_length",
      "type": "VARIABLE",
      "behavior": {
        "value": "1",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "radius_of_pendulum_mass",
      "type": "VARIABLE",
      "behavior": {
        "value": "0",
        "description": "",
        "units": "Unitless"
      }
    },
