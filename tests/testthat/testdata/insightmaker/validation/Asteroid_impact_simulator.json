{
  "engine": "SIMULATION_PACKAGE",
  "name": "Asteroid impact simulator",
  "simulation": {
    "version": "37",
    "time_length": "20",
    "time_start": "0",
    "time_step": "0.1",
    "time_units": "SECONDS",
    "algorithm": "RK1"
  },
  "elements": [
    {
      "name": "Area",
      "type": "VARIABLE",
      "behavior": {
        "value": "(([Diameter]/2)*([Diameter]/2))*pi",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Friction_force",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Area]*(1/2)*[flow_resistance]*[Air_density]*([velocity]*[velocity])",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "flow_resistance",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.6",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "mass",
      "type": "VARIABLE",
      "behavior": {
        "value": "((([Diameter]/2)*([Diameter]/2)*([Diameter]/2))*(4/3)*pi)*[densityasteroid]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "g_force",
      "type": "VARIABLE",
      "behavior": {
        "value": "([Gravitational_Force]/[mass])*-1",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "weight_Force",
      "type": "VARIABLE",
      "behavior": {
        "value": "[g_force]*[mass]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "total_force",
      "type": "VARIABLE",
      "behavior": {
        "value": "([weight_Force]+[Friction_force])",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "acceleration",
      "type": "VARIABLE",
      "behavior": {
        "value": "[total_force]/[mass]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "velocity",
      "type": "STOCK",
      "behavior": {
        "initial_value": "[initial_velocity]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Flow",
      "type": "FLOW",
      "from": null,
      "to": "velocity",
      "behavior": {
        "value": "[acceleration]",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "height__decrasing",
      "type": "STOCK",
      "behavior": {
        "initial_value": "[initial_height]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "initial_height",
      "type": "VARIABLE",
      "behavior": {
        "value": "100000",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Flow_1",
      "type": "FLOW",
      "from": null,
      "to": "height__decrasing",
      "behavior": {
        "value": "If [height__decrasing] > 0 Then\n  [velocity]\nElse If [height__decrasing] < 0 Then\n  0\nEnd If",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Air_density",
      "type": "VARIABLE",
      "behavior": {
        "value": "If [height__decrasing] > 0 Then\n  ([initial_air_density]*Exp(-0.1381*([height__decrasing]/1000)))\nElse If [height__decrasing] < 0 Then\n  ([initial_air_density])\nEnd If",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "initial_air_density",
      "type": "VARIABLE",
      "behavior": {
        "value": "1.23",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "spec__Heat_capacity",
      "type": "VARIABLE",
      "behavior": {
        "value": "1000",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "densityasteroid",
      "type": "VARIABLE",
      "behavior": {
        "value": "2630",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "thermal_cunductivity",
      "type": "VARIABLE",
      "behavior": {
        "value": "100",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "seconds",
      "type": "VARIABLE",
      "behavior": {
        "value": "1",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Time",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0.01",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Flow_2",
      "type": "FLOW",
      "from": null,
      "to": "Time",
      "behavior": {
        "value": "[seconds]",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Temperature_generated",
      "type": "VARIABLE",
      "behavior": {
        "value": "[friction_energy]/([spec__Heat_capacity]*[mass])",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "height__increasing",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Flow_3",
      "type": "FLOW",
      "from": "height__increasing",
      "to": null,
      "behavior": {
        "value": "[velocity]",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "kinetic_energy",
      "type": "VARIABLE",
      "behavior": {
        "value": "(1/2)*[mass]*([velocity]*[velocity])",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "potential_energy",
      "type": "VARIABLE",
      "behavior": {
        "value": "-1*[g_force]*[height__decrasing]*[mass]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "friction_energy",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Friction_force]*[height__increasing]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "total_energy",
      "type": "VARIABLE",
      "behavior": {
        "value": "([initial_height]*[mass]*[g_force]*-1)+((1/2)*[mass]*([initial_velocity]*[initial_velocity]))",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "melting_temperature_asteroid",
      "type": "VARIABLE",
      "behavior": {
        "value": "1800",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "initial_velocity",
      "type": "VARIABLE",
      "behavior": {
        "value": "-20000",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Diameter",
      "type": "VARIABLE",
      "behavior": {
        "value": "12500",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Heat_loss",
      "type": "VARIABLE",
      "behavior": {
        "value": "([thermal_cunductivity]*[Area])*[Temperature_generated]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Temperature_loss",
      "type": "VARIABLE",
      "behavior": {
        "value": "([Time]*[Heat_loss])/([mass]*[spec__Heat_capacity])",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Temperature_Asteroid",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Actual_Temperature]-[Temperature_loss]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "When_melted",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Melting_Heat_Asteroid] < 0.1",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Impact_energy",
      "type": "VARIABLE",
      "behavior": {
        "value": "If [Melting_Heat_Asteroid] < 0.1 Then\n  0\nElse If [height__decrasing] < 0.1 Then\n  [kinetic_energy]\nEnd If",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "TNT_Energy",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Impact_energy]*(2.3901*10^-6)",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Hiroshima_Bombs",
      "type": "VARIABLE",
      "behavior": {
        "value": "[TNT_Energy]/13000000",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Actual_Temperature",
      "type": "VARIABLE",
      "behavior": {
        "value": "If ([friction_energy]/([spec__Heat_capacity]*[mass])) < [melting_temperature_asteroid] Then\n  ([friction_energy]/([spec__Heat_capacity]*[mass]))\nElse If ([friction_energy]/([spec__Heat_capacity]*[mass])) > [melting_temperature_asteroid] Then\n  [melting_temperature_asteroid]\nElse If [Melting_Heat_Asteroid] < 0.1 Then\n  ([friction_energy]/([spec__Heat_capacity]*[mass]))\nEnd If",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Heat_generated",
      "type": "VARIABLE",
      "behavior": {
        "value": "[spec__Heat_capacity]*[mass]*[Actual_Temperature]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Melting_Heat_Asteroid",
      "type": "STOCK",
      "behavior": {
        "initial_value": "500000*[mass]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Flow_4",
      "type": "FLOW",
      "from": "Melting_Heat_Asteroid",
      "to": null,
      "behavior": {
        "value": "If [Actual_Temperature] < [melting_temperature_asteroid] Then\n  0\nElse If [Actual_Temperature] = [melting_temperature_asteroid] Then\n  [Heat_generated]\nElse If [Melting_Heat_Asteroid] = 0 Then\n  0\nEnd If",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Gravitational_constant",
      "type": "VARIABLE",
      "behavior": {
        "value": "6.637*10^-11",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "distance_Earth_Asteroid",
      "type": "VARIABLE",
      "behavior": {
        "value": "6370000+[height__decrasing]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Gravitational_Force",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Gravitational_constant]*(([mass]*5.972*1000000000000000000000000)/([distance_Earth_Asteroid]*[distance_Earth_Asteroid]))",
        "description": "",
        "units": "Unitless"
      }
    },
