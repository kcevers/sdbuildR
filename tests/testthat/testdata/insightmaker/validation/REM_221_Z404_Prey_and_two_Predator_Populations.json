{
  "engine": "SIMULATION_PACKAGE",
  "name": "REM 221 - Z404 Prey and two Predator Populations",
  "simulation": {
    "version": "36",
    "time_length": "200",
    "time_start": "0",
    "time_step": "0.05",
    "time_units": "MONTHS",
    "algorithm": "RK1"
  },
  "elements": [
    {
      "name": "predator_A",
      "type": "STOCK",
      "behavior": {
        "initial_value": "[INITIAL_PREDATOR_A]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "predator_B",
      "type": "STOCK",
      "behavior": {
        "initial_value": "[INITIAL_PREDATOR_B]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "prey",
      "type": "STOCK",
      "behavior": {
        "initial_value": "[INITIAL_PREY]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "predator_A_loss",
      "type": "FLOW",
      "from": "predator_A",
      "to": null,
      "behavior": {
        "value": "([ENERGY_CONSUMPTION_RATE_A] *[predator_A])+([HUNT_LIMIT_A]*[predator_A])",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "predator_B_loss",
      "type": "FLOW",
      "from": "predator_B",
      "to": null,
      "behavior": {
        "value": "([ENERGY_CONSUMPTION_RATE_B]*[predator_B])+([HUNT_LIMIT_B]*[predator_B])",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "prey_loss",
      "type": "FLOW",
      "from": "prey",
      "to": null,
      "behavior": {
        "value": "[LOSS_CAUSED_BY_PREDATOR_A] *[prey_encounters_predator_A] +[LOSS_CAUSED_BY_PREDATOR_B] *[prey_encounters_predator_B]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "predator_B_gain",
      "type": "FLOW",
      "from": null,
      "to": "predator_B",
      "behavior": {
        "value": "[PREY_GAIN_PREDATOR_B] *[prey_encounters_predator_B]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "predator_A_gain",
      "type": "FLOW",
      "from": null,
      "to": "predator_A",
      "behavior": {
        "value": "[PREY_GAIN_PREDATOR_A] *[prey_encounters_predator_A]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "prey_gain",
      "type": "FLOW",
      "from": null,
      "to": "prey",
      "behavior": {
        "value": "[GROWTH_RATE_PREY]*[prey]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "ENERGY_CONSUMPTION_RATE_A",
      "type": "VARIABLE",
      "behavior": {
        "value": ".12",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "ENERGY_CONSUMPTION_RATE_B",
      "type": "VARIABLE",
      "behavior": {
        "value": ".1",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "PREY_GAIN_PREDATOR_B",
      "type": "VARIABLE",
      "behavior": {
        "value": ".1",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "prey_encounters_predator_B",
      "type": "VARIABLE",
      "behavior": {
        "value": "[predator_B]*[prey]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "prey_encounters_predator_A",
      "type": "VARIABLE",
      "behavior": {
        "value": "[prey]*[predator_A]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
