{
  "engine": "SIMULATION_PACKAGE",
  "name": "The SIC (Susceptible-Infected-Concern) Model",
  "simulation": {
    "version": "37",
    "time_length": "80",
    "time_start": "0",
    "time_step": "0.5",
    "time_units": "DAYS",
    "algorithm": "RK1"
  },
  "elements": [
    {
      "name": "Growth",
      "type": "FLOW",
      "from": null,
      "to": "Concern",
      "behavior": {
        "value": "[Fraction_Infected]*[Concern_Growth_Rate]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Decay",
      "type": "FLOW",
      "from": "Concern",
      "to": null,
      "behavior": {
        "value": "[Concern_Decay_Rate]*[Concern]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Susceptible",
      "type": "STOCK",
      "behavior": {
        "initial_value": "90",
        "description": "The initial number of susceptible people.",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Infected",
      "type": "STOCK",
      "behavior": {
        "initial_value": "10",
        "description": "The initial number of infected people.",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Infection",
      "type": "FLOW",
      "from": "Susceptible",
      "to": "Infected",
      "behavior": {
        "value": "[Effective_Contact_Rate]*[Susceptible]*[Infected]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Recovery",
      "type": "FLOW",
      "from": "Infected",
      "to": "Susceptible",
      "behavior": {
        "value": "[Infected]*[Recovery_Rate]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Recovery_Rate",
      "type": "VARIABLE",
      "behavior": {
        "value": ".2",
        "description": "The rate at which people recover. (1/average infection duration)",
        "units": "Unitless"
      }
    },
    {
      "name": "Maximum_Contact_Rate",
      "type": "VARIABLE",
      "behavior": {
        "value": ".015",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Concern",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "The concern in the population.",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Fraction_Infected",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Infected]/([Susceptible]+[Infected])",
        "description": "The fraction of the population that is infected.",
        "units": "Unitless"
      }
    },
    {
      "name": "Concern_Decay_Rate",
      "type": "VARIABLE",
      "behavior": {
        "value": ".05",
        "description": "The first-order exponential decay rate of concern.",
        "units": "Unitless"
      }
    },
    {
      "name": "Concern_Growth_Rate",
      "type": "VARIABLE",
      "behavior": {
        "value": "1",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Response_Efficiency",
      "type": "VARIABLE",
      "behavior": {
        "value": "1",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Effective_Contact_Rate",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Maximum_Contact_Rate]*[Response_Efficiency]/([Concern]+[Response_Efficiency])",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "type": "LINK",
      "from": "Fraction_Infected",
      "to": "Growth"
    },
    {
      "type": "LINK",
      "from": "Concern_Growth_Rate",
      "to": "Growth"
    },
    {
      "type": "LINK",
      "from": "Concern",
      "to": "Growth"
    },
    {
      "type": "LINK",
      "from": "Concern",
      "to": "Decay"
    },
    {
      "type": "LINK",
      "from": "Concern_Decay_Rate",
      "to": "Decay"
    },
    {
      "type": "LINK",
      "from": "Concern",
      "to": "Decay"
    },
    {
      "type": "LINK",
      "from": "Susceptible",
      "to": "Infection"
    },
    {
      "type": "LINK",
      "from": "Infected",
      "to": "Infection"
    },
    {
      "type": "LINK",
      "from": "Effective_Contact_Rate",
      "to": "Infection"
    },
    {
      "type": "LINK",
      "from": "Susceptible",
      "to": "Infection"
    },
    {
      "type": "LINK",
      "from": "Infected",
      "to": "Infection"
    },
    {
      "type": "LINK",
      "from": "Infected",
      "to": "Recovery"
    },
    {
      "type": "LINK",
      "from": "Recovery_Rate",
      "to": "Recovery"
    },
    {
      "type": "LINK",
      "from": "Infected",
      "to": "Recovery"
    },
    {
      "type": "LINK",
      "from": "Susceptible",
      "to": "Recovery"
    },
    {
      "type": "LINK",
      "from": "Susceptible",
      "to": "Fraction_Infected"
    },
    {
      "type": "LINK",
      "from": "Infected",
      "to": "Fraction_Infected"
    },
    {
      "type": "LINK",
      "from": "Infected",
      "to": "Fraction_Infected"
    },
    {
      "type": "LINK",
      "from": "Maximum_Contact_Rate",
      "to": "Effective_Contact_Rate"
    },
    {
      "type": "LINK",
      "from": "Concern",
      "to": "Effective_Contact_Rate"
    },
    {
      "type": "LINK",
      "from": "Response_Efficiency",
      "to": "Effective_Contact_Rate"
    },
    {
      "type": "LINK",
      "from": "Response_Efficiency",
      "to": "Effective_Contact_Rate"
    }
  ],
  "engine_settings": []
}
