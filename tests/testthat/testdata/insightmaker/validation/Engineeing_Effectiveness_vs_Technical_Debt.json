{
  "engine": "SIMULATION_PACKAGE",
  "name": "Engineeing Effectiveness vs Technical Debt",
  "simulation": {
    "version": "37",
    "time_length": "90",
    "time_start": "0",
    "time_step": "1",
    "time_units": "DAYS",
    "algorithm": "RK1"
  },
  "elements": [
    {
      "name": "Product_Backlog",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Customer_Value",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "New_User_Story",
      "type": "FLOW",
      "from": null,
      "to": "Product_Backlog",
      "behavior": {
        "value": "1-Ramp([First_Day_Investing], [First_Day_Investing]+20, [Team_Capacity_to_Improvements])",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Development",
      "type": "FLOW",
      "from": "Product_Backlog",
      "to": "Customer_Value",
      "behavior": {
        "value": "1-[Investing_in_TechDebt]-[Effort]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Technical_Debt",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Quality",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.1",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Introducing_Technical_Debt",
      "type": "FLOW",
      "from": null,
      "to": "Technical_Debt",
      "behavior": {
        "value": "1 - [Quality] - Ramp([First_Day_Investing], [First_Day_Investing]+20, [Team_Capacity_to_Improvements])",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Effort",
      "type": "VARIABLE",
      "behavior": {
        "value": "1-(((100-[Technical_Debt])/100)^2)+([Quality]/2)\n",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Continuous_Improvement_Tasks",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Adds_CI_Task",
      "type": "FLOW",
      "from": null,
      "to": "Continuous_Improvement_Tasks",
      "behavior": {
        "value": "-[Investing_in_TechDebt]",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Investing_in_TechDebt",
      "type": "VARIABLE",
      "behavior": {
        "value": "Ramp([First_Day_Investing], [First_Day_Investing]+20, [Team_Capacity_to_Improvements])",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "First_Day_Investing",
      "type": "VARIABLE",
      "behavior": {
        "value": "30",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Team_Capacity_to_Improvements",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.7",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Decreases_Technical_Debt",
      "type": "FLOW",
      "from": "Continuous_Improvement_Tasks",
      "to": "Technical_Debt",
      "behavior": {
        "value": "[Continuous_Improvement_Tasks]",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "type": "LINK",
