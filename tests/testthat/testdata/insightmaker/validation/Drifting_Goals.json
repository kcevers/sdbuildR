{
  "engine": "SIMULATION_PACKAGE",
  "name": "Drifting Goals",
  "simulation": {
    "version": "37",
    "time_length": "20",
    "time_start": "0",
    "time_step": "0.5",
    "time_units": "WEEKS",
    "algorithm": "RK1"
  },
  "elements": [
    {
      "name": "what_i_want",
      "type": "VARIABLE",
      "behavior": {
        "value": "0",
        "description": "The objective or state of things I want to bring into being.",
        "units": "Unitless"
      }
    },
    {
      "name": "gap",
      "type": "VARIABLE",
      "behavior": {
        "value": "0",
        "description": "The difference  between what I want and what I have. The gap serves as a motivator for action.",
        "units": "Unitless"
      }
    },
    {
      "name": "what_i_have",
      "type": "VARIABLE",
      "behavior": {
        "value": "0",
        "description": "The current state of things.",
        "units": "Unitless"
      }
    },
    {
      "name": "action_to_get_what_i_want",
      "type": "VARIABLE",
      "behavior": {
        "value": "0",
        "description": "The action taken based on the gap intended to move what I have in the direction of what I want.",
        "units": "Unitless"
      }
    },
    {
      "name": "pressure_to_settle_for_less",
      "type": "VARIABLE",
      "behavior": {
        "value": "0",
        "description": "The gap in addition to inducing action to get what I want creates a pressure for me to settle for less than I initially wanted.",
        "units": "Unitless"
      }
    },
    {
      "name": "desired_state",
      "type": "STOCK",
      "behavior": {
        "initial_value": "1",
        "description": "The desired state we wish to achieve.",
        "units": "Unitless"
      }
    },
    {
      "name": "goal_reduction",
      "type": "FLOW",
      "from": "desired_state",
      "to": null,
      "behavior": {
        "value": "[tension]*[goal_chg_fact]",
        "description": "The goal reduction is simply the tension times the foal change factor.",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "current_state_1",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "The current state that is to be migrated in the direction of the desired state.",
        "units": "Unitless"
      }
    },
    {
      "name": "action",
      "type": "FLOW",
      "from": null,
      "to": "current_state_1",
      "behavior": {
        "value": "[tension]*[pct_chg_fact]",
        "description": "Action intended to migrate the current state in the direction of the desired state.",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "tension",
      "type": "VARIABLE",
      "behavior": {
        "value": "[desired_state]-[current_state_1]",
        "description": "tension created based on the difference between the current state and the desired state.",
        "units": "Unitless"
      }
    },
    {
      "name": "pct_chg_fact",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.2",
        "description": "A factor used to control the rate of action influence during the simulation.",
        "units": "Unitless"
      }
    },
    {
      "name": "goal_chg_fact",
      "type": "VARIABLE",
      "behavior": {
        "value": "0",
        "description": "This is just a factor to control the rate of goal reduction.",
        "units": "Unitless"
      }
    },
    {
      "type": "LINK",
      "from": "tension",
      "to": "goal_reduction"
    },
    {
      "type": "LINK",
      "from": "goal_chg_fact",
      "to": "goal_reduction"
    },
    {
      "type": "LINK",
      "from": "desired_state",
      "to": "goal_reduction"
    },
    {
      "type": "LINK",
      "from": "tension",
      "to": "action"
    },
    {
      "type": "LINK",
      "from": "pct_chg_fact",
      "to": "action"
    },
    {
      "type": "LINK",
      "from": "current_state_1",
      "to": "action"
    },
    {
      "type": "LINK",
      "from": "desired_state",
      "to": "tension"
    },
    {
      "type": "LINK",
      "from": "current_state_1",
      "to": "tension"
    }
  ],
  "engine_settings": []
}
