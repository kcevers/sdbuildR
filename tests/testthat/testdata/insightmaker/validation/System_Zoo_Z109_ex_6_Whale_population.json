{
  "engine": "SIMULATION_PACKAGE",
  "name": "System Zoo Z109 ex 6: Whale population",
  "simulation": {
    "version": "22",
    "time_length": "100",
    "time_start": "0",
    "time_step": "1",
    "time_units": "YEARS",
    "algorithm": "RK4"
  },
  "elements": [
    {
      "name": "population",
      "type": "STOCK",
      "behavior": {
        "initial_value": "[INITIAL_POPULATION]",
        "description": "",
        "units": "Whales"
      }
    },
    {
      "name": "births",
      "type": "FLOW",
      "from": null,
      "to": "population",
      "behavior": {
        "value": "[population]*[BIRTH_RATE]*(1-[population]/[CARRYING_CAPACITY])",
        "description": "",
        "units": "Whales per Year",
        "non_negative": true
      }
    },
    {
      "name": "harvest",
      "type": "FLOW",
      "from": "population",
      "to": null,
      "behavior": {
        "value": "[HARVEST_RATE]*[population]",
        "description": "",
        "units": "Whales per Year",
        "non_negative": true
      }
    },
    {
      "name": "BIRTH_RATE",
      "type": "VARIABLE",
      "behavior": {
        "value": "IfThenElse([population]>=[MINIMUM_REPRODUCTIVE_POPULATION], [NORMAL_BIRTH_RATE], 0)",
        "description": "",
        "units": "Years^-1"
      }
    },
    {
      "name": "CARRYING_CAPACITY",
      "type": "VARIABLE",
      "behavior": {
        "value": "100000",
        "description": "",
        "units": "Whales"
      }
    },
    {
      "name": "HARVEST_RATE",
      "type": "VARIABLE",
      "behavior": {
        "value": "0",
        "description": "",
        "units": "Years^-1"
      }
    },
    {
      "name": "INITIAL_POPULATION",
      "type": "VARIABLE",
      "behavior": {
        "value": "20000",
        "description": "",
        "units": "Whales"
      }
    },
    {
      "name": "deaths",
      "type": "FLOW",
      "from": "population",
      "to": null,
      "behavior": {
        "value": "[population]*[DEATH_RATE]",
        "description": "",
        "units": "Whales per Year",
        "non_negative": true
      }
    },
    {
      "name": "NORMAL_BIRTH_RATE",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.1",
        "description": "",
        "units": "Years^-1"
      }
    },
    {
      "name": "DEATH_RATE",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.05",
        "description": "",
        "units": "Years^-1"
      }
    },
    {
      "name": "MINIMUM_REPRODUCTIVE_POPULATION",
      "type": "VARIABLE",
      "behavior": {
        "value": "0",
        "description": "",
        "units": "Whales"
      }
    },
    {
      "type": "LINK",
      "from": "INITIAL_POPULATION",
      "to": "population"
    },
    {
      "type": "LINK",
      "from": "population",
      "to": "births"
    },
    {
      "type": "LINK",
      "from": "population",
      "to": "births"
    },
    {
      "type": "LINK",
      "from": "BIRTH_RATE",
      "to": "births"
    },
    {
      "type": "LINK",
      "from": "CARRYING_CAPACITY",
      "to": "births"
    },
    {
      "type": "LINK",
      "from": "population",
      "to": "births"
    },
    {
      "type": "LINK",
      "from": "population",
      "to": "harvest"
    },
    {
      "type": "LINK",
      "from": "HARVEST_RATE",
      "to": "harvest"
    },
    {
      "type": "LINK",
      "from": "population",
      "to": "harvest"
    },
    {
      "type": "LINK",
      "from": "population",
      "to": "BIRTH_RATE"
    },
    {
      "type": "LINK",
      "from": "NORMAL_BIRTH_RATE",
      "to": "BIRTH_RATE"
    },
    {
      "type": "LINK",
      "from": "MINIMUM_REPRODUCTIVE_POPULATION",
      "to": "BIRTH_RATE"
    },
    {
      "type": "LINK",
      "from": "population",
      "to": "deaths"
    },
    {
      "type": "LINK",
      "from": "DEATH_RATE",
      "to": "deaths"
    },
    {
      "type": "LINK",
      "from": "population",
      "to": "deaths"
    }
  ],
  "engine_settings": {
    "units": [
      [
        {
          "name": "whales",
          "factor": "1",
          "base": ""
        }
      ],
      [
        {
          "name": "whales per year",
          "factor": "1",
          "base": "whales/years"
        }
      ]
    ]
  }
}
