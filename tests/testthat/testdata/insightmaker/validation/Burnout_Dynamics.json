{
  "engine": "SIMULATION_PACKAGE",
  "name": "Burnout Dynamics",
  "simulation": {
    "version": "37",
    "time_length": "25",
    "time_start": "0",
    "time_step": "0.125",
    "time_units": "WEEKS",
    "algorithm": "RK1"
  },
  "elements": [
    {
      "name": "Work_to_Do",
      "type": "STOCK",
      "behavior": {
        "initial_value": "[Initial_Work_to_Do]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "new_work_arriving",
      "type": "FLOW",
      "from": null,
      "to": "Work_to_Do",
      "behavior": {
        "value": "[usual_new_work_per_week]+[additional_new_work]",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "usual_new_work_per_week",
      "type": "VARIABLE",
      "behavior": {
        "value": "46.79",
        "description": "default is 40",
        "units": "Unitless"
      }
    },
    {
      "name": "additional_new_work",
      "type": "VARIABLE",
      "behavior": {
        "value": "Pulse(5, [Size_of_additional_work], timestep)",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "accomplishing",
      "type": "FLOW",
      "from": "Work_to_Do",
      "to": null,
      "behavior": {
        "value": "[Productivity]*[hours_worked_per_week]",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "usual_hours_worked_per_week",
      "type": "VARIABLE",
      "behavior": {
        "value": "33.12",
        "description": "default is 40",
        "units": "Unitless"
      }
    },
    {
      "name": "hours_worked_per_week",
      "type": "VARIABLE",
      "behavior": {
        "value": "[usual_hours_worked_per_week]*[Impact_of_Backlog_on_hours_worked]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Productivity",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Usual_Productivity]*[Impact_of_Burnout_on_Productivity]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Usual_Productivity",
      "type": "VARIABLE",
      "behavior": {
        "value": "1",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Burnout",
      "type": "STOCK",
      "behavior": {
        "initial_value": "8",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "building",
      "type": "FLOW",
      "from": null,
      "to": "Burnout",
      "behavior": {
        "value": "[hours_worked_per_week]*[Burnout_per_hour]",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "recovering",
      "type": "FLOW",
      "from": "Burnout",
      "to": null,
      "behavior": {
        "value": "[Burnout]/[Burnout_recovery_time]",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "usual_burnout_per_hour",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.1",
        "description": "default is 0.1",
        "units": "Unitless"
      }
    },
    {
      "name": "Burnout_per_hour",
      "type": "VARIABLE",
      "behavior": {
        "value": "[usual_burnout_per_hour]*[Impact_of_hours_worked_on_Burnout]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Burnout_recovery_time",
      "type": "VARIABLE",
      "behavior": {
        "value": "[usual_recovery_time_wks]*[Impact_of_Burnout_on_recovery]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "usual_recovery_time_wks",
      "type": "VARIABLE",
      "behavior": {
        "value": "2",
        "description": "default is 2",
        "units": "Unitless"
      }
    },
    {
      "name": "Initial_Work_to_Do",
      "type": "VARIABLE",
      "behavior": {
        "value": "32.4",
        "description": "default is 32.4",
        "units": "Unitless"
      }
    },
