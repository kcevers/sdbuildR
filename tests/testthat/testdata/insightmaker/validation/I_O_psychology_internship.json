{
  "engine": "SIMULATION_PACKAGE",
  "name": "I/O psychology internship",
  "simulation": {
    "version": "36",
    "time_length": "25",
    "time_start": "0",
    "time_step": "0.5",
    "time_units": "HOURS",
    "algorithm": "RK1"
  },
  "elements": [
    {
      "name": "B",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "This stock is the unintended consequence of implementing change A.",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Problem",
      "type": "STOCK",
      "behavior": {
        "initial_value": "100",
        "description": "Problems are treated as a stock.",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Increase_in_Problem",
      "type": "FLOW",
      "from": null,
      "to": "Problem",
      "behavior": {
        "value": "[Effect_of_B]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Fix",
      "type": "FLOW",
      "from": "Problem",
      "to": null,
      "behavior": {
        "value": "[Problem]*[Problem_elimination_normal]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "A",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "This is the fix that the leaders of the organization have in mind.",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Change_in_A",
      "type": "FLOW",
      "from": null,
      "to": "A",
      "behavior": {
        "value": "([Fix]-[A])/[Time_to_Change]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Growth_in_B",
      "type": "FLOW",
      "from": null,
      "to": "B",
      "behavior": {
        "value": "[A]*[Fraction_of_A_creating_B]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Reduction_in_B",
      "type": "FLOW",
      "from": "B",
      "to": null,
      "behavior": {
        "value": "[B]*[Dissipation_normal]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Time_to_Change",
      "type": "VARIABLE",
      "behavior": {
        "value": "1",
        "description": "Usually, it takes time for a change to have an effect.",
        "units": "Unitless"
      }
    },
    {
      "name": "Fraction_of_A_creating_B",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.88",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Problem_elimination_normal",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.25",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Dissipation_normal",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.1",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Effect_of_B",
      "type": "CONVERTER",
      "behavior": {
        "input": "ELEMENT",
        "input_element": "B",
        "interpolation": "LINEAR",
        "data": [
            [0, 0],
            [10, 0],
            [20, 0],
            [30, 1],
            [40, 6.5],
            [50, 12.5],
            [60, 16],
            [70, 21],
            [80, 26],
            [90, 37],
            [100, 49]
          ],
        "units": "Unitless"
      }
    },
    {
      "type": "LINK",
      "from": "Effect_of_B",
      "to": "Increase_in_Problem"
    },
    {
      "type": "LINK",
      "from": "Problem",
      "to": "Increase_in_Problem"
    },
    {
      "type": "LINK",
      "from": "Problem",
      "to": "Fix"
    },
    {
      "type": "LINK",
      "from": "Problem_elimination_normal",
      "to": "Fix"
    },
    {
      "type": "LINK",
      "from": "Problem",
      "to": "Fix"
    },
    {
      "type": "LINK",
      "from": "Fix",
      "to": "Change_in_A"
    },
    {
      "type": "LINK",
      "from": "A",
      "to": "Change_in_A"
    },
    {
      "type": "LINK",
      "from": "Time_to_Change",
      "to": "Change_in_A"
    },
    {
      "type": "LINK",
      "from": "A",
      "to": "Change_in_A"
    },
    {
      "type": "LINK",
      "from": "A",
      "to": "Growth_in_B"
    },
    {
      "type": "LINK",
      "from": "Fraction_of_A_creating_B",
      "to": "Growth_in_B"
    },
    {
      "type": "LINK",
      "from": "B",
      "to": "Growth_in_B"
    },
    {
      "type": "LINK",
      "from": "B",
      "to": "Reduction_in_B"
    },
    {
      "type": "LINK",
      "from": "Dissipation_normal",
      "to": "Reduction_in_B"
    },
    {
      "type": "LINK",
      "from": "B",
      "to": "Reduction_in_B"
    }
  ],
  "engine_settings": []
}
