{
  "engine": "SIMULATION_PACKAGE",
  "name": "Aggression",
  "simulation": {
    "version": "37",
    "time_length": "50",
    "time_start": "0",
    "time_step": "0.5",
    "time_units": "MONTHS",
    "algorithm": "RK1"
  },
  "elements": [
    {
      "name": "unfamiliarity",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0.1",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "education_effort",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Education_Activity]*Staircase(15, 1)",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "tolerance",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0.5",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "education",
      "type": "FLOW",
      "from": null,
      "to": "tolerance",
      "behavior": {
        "value": "[education_effort]*[tolerance]*(1-[Max_Tolerance])",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Education_Activity",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.5",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "tolerance_erosion",
      "type": "FLOW",
      "from": "tolerance",
      "to": null,
      "behavior": {
        "value": "[tolerance]*[hate]/[Learning_Time]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "hate",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0.1",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "hate_increase",
      "type": "FLOW",
      "from": null,
      "to": "hate",
      "behavior": {
        "value": "[unfamiliarity]*[intolerance]*[social_problems]*[hate]*(1-[hate]/[max_hate])/[Learning_Time]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "hate_decrease",
      "type": "FLOW",
      "from": "hate",
      "to": null,
      "behavior": {
        "value": "[hate]*[tolerance]/[Learning_Time]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "restraint_threshold",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0.5",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "restraint_buildup",
      "type": "FLOW",
      "from": null,
      "to": "restraint_threshold",
      "behavior": {
        "value": "[max_restraint]*[restraint_threshold]*(1-[restraint_threshold]/[max_restraint])/[Learning_Time]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "restraint_loss",
      "type": "FLOW",
      "from": "restraint_threshold",
      "to": null,
      "behavior": {
        "value": "[hate]*[social_problems]*[violence_in_media]*[restraint_threshold]/[Learning_Time]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Max_Tolerance",
      "type": "VARIABLE",
      "behavior": {
        "value": "1",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "intolerance",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Max_Tolerance]-[tolerance]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "unfamiliar_experience",
      "type": "FLOW",
      "from": null,
      "to": "unfamiliarity",
      "behavior": {
        "value": "[intolerance]*[Degree_of_Unfamiliarity]*[encounters]*[Encounter_Intensity]*[unfamiliarity]*(1-[unfamiliarity]/[Max_Unfamiliarity])",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "accustoming",
      "type": "FLOW",
      "from": "unfamiliarity",
      "to": null,
      "behavior": {
        "value": "[unfamiliarity]*[tolerance]/[Learning_Time]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Encounter_Interval",
      "type": "VARIABLE",
      "behavior": {
        "value": "2",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Encounter_Intensity",
      "type": "VARIABLE",
      "behavior": {
        "value": "5",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Max_Unfamiliarity",
      "type": "VARIABLE",
      "behavior": {
        "value": "1",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Degree_of_Unfamiliarity",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.5",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "encounters",
      "type": "VARIABLE",
      "behavior": {
        "value": "Pulse([Encounter_Interval], 1, 50)",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Learning_Time",
      "type": "VARIABLE",
      "behavior": {
        "value": "5",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Violence",
      "type": "VARIABLE",
      "behavior": {
        "value": "[hate]*[violent_action]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "violent_action",
      "type": "VARIABLE",
      "behavior": {
        "value": "IfThenElse([hate]-[restraint_threshold]>0, 1, 0)",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "violence_in_media",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.4",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "ethical_scruples",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.1",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "max_restraint",
      "type": "VARIABLE",
      "behavior": {
        "value": "[govt_authority]*(1-[violence_in_media])+[ethical_scruples]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "govt_authority",
      "type": "VARIABLE",
      "behavior": {
        "value": "Staircase(10, 1)",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Govt_Resolve",
