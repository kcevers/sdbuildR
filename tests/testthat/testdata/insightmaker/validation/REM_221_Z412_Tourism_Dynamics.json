        "initial_value": "1",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "tourist_lost",
      "type": "FLOW",
      "from": "tourist",
      "to": null,
      "behavior": {
        "value": "[LOSS_RATE]*[tourist]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
