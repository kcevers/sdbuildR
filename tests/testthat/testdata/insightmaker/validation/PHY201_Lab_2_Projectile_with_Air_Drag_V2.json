      "type": "STOCK",
      "behavior": {
        "initial_value": "100",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "velocity",
      "type": "VARIABLE",
      "behavior": {
        "value": "Min([momentum]/[mass],54)",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "mass",
      "type": "VARIABLE",
      "behavior": {
        "value": "# mass object (in kg)\n2",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "gravity",
      "type": "VARIABLE",
      "behavior": {
        "value": "-9.8",
        "description": "",
        "units": "Unitless"
      }
