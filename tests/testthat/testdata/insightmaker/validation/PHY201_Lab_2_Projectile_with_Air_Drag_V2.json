{
  "engine": "SIMULATION_PACKAGE",
  "name": "PHY201 - Lab 2 - Projectile with Air Drag (V2)",
  "simulation": {
    "version": "36",
    "time_length": "10",
    "time_start": "0",
    "time_step": "0.1",
    "time_units": "SECONDS",
    "algorithm": "RK1"
  },
  "elements": [
