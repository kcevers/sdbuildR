    {
      "name": "momentum",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Flow_1",
      "type": "FLOW",
      "from": null,
      "to": "momentum",
      "behavior": {
        "value": "[gravity]+[air_drag]",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "air_drag",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.5*[air_density]*([velocity]*[velocity])*[drag_coefficient]*[x_sect_area]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "air_density",
      "type": "VARIABLE",
      "behavior": {
        "value": "# density of air at 70-deg F is ~ 1.2 (kg/m^3)\n1.2",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "drag_coefficient",
      "type": "VARIABLE",
      "behavior": {
        "value": "# drag coefficient for a sphere\n0.47",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "x_sect_area",
      "type": "VARIABLE",
      "behavior": {
        "value": "# sphere's cross-sectional area\n# pi * ( radius ^ 2 )\npi*(1^2)",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "type": "LINK",
      "from": "velocity",
      "to": "Flow"
    },
    {
      "type": "LINK",
      "from": "Position",
      "to": "Flow"
    },
    {
      "type": "LINK",
