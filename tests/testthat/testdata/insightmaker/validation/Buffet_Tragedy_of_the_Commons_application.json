{
  "engine": "SIMULATION_PACKAGE",
  "name": "Buffet - Tragedy of the Commons application",
  "simulation": {
    "version": "34",
    "time_length": "10",
    "time_start": "0",
    "time_step": "0.5",
    "time_units": "MINUTES",
    "algorithm": "RK1"
  },
  "elements": [
    {
      "name": "Person1_plate_empty",
      "type": "STOCK",
      "behavior": {
        "initial_value": "1",
        "description": "",
