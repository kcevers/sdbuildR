      "behavior": {
        "initial_value": "50",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Person1_plate_refill",
      "type": "FLOW",
      "from": "Buffet",
      "to": "Person1_plate_empty",
      "behavior": {
        "value": "IfThenElse([Mouth_size_person1]*[Person1_plate_empty]<[Buffet], [Mouth_size_person1]*[Person1_plate_empty], [Buffet])",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Person2_plate_refill",
      "type": "FLOW",
      "from": "Buffet",
      "to": "Person2_plate_empty",
