{
  "engine": "SIMULATION_PACKAGE",
  "name": "SEIRD 01: COVID-19 spread",
  "simulation": {
    "version": "37",
    "time_length": "150",
    "time_start": "0",
    "time_step": "0.25",
    "time_units": "DAYS",
    "algorithm": "RK1"
  },
  "elements": [
    {
      "name": "Susceptible",
      "type": "STOCK",
      "behavior": {
        "initial_value": "8000000",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Infective",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Recovered",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "to_exposed",
      "type": "FLOW",
      "from": "Susceptible",
      "to": "Exposed",
      "behavior": {
        "value": "IfThenElse([Susceptible]<1, 0, [initiation]+[New_cases])",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "recoveries",
      "type": "FLOW",
      "from": "Infective",
      "to": "Recovered",
      "behavior": {
        "value": "([Infective]/[Days_infected])*((100-[Fatality_rate])/100)",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "initiation",
      "type": "VARIABLE",
      "behavior": {
        "value": "Pulse(0,4,0.25)",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "New_cases",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Infective]*[Contacts_per_day]*[Infectivity]*[Probability_of_meeting_a_susceptible_person]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Contacts_per_day",
      "type": "VARIABLE",
      "behavior": {
        "value": "7.42",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Infectivity",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.42",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Total_Population",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Susceptible]+[Exposed]+[Infective]+[Recovered]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Probability_of_meeting_a_susceptible_person",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Susceptible]/[Total_Population]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Days_infected",
      "type": "VARIABLE",
      "behavior": {
        "value": "14.39",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Exposed",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "becoming_infectious",
      "type": "FLOW",
      "from": "Exposed",
      "to": "Infective",
      "behavior": {
        "value": "[Exposed]/[Incubation_period]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Incubation_period",
      "type": "VARIABLE",
      "behavior": {
        "value": "6.38",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Death",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Fatalities",
      "type": "FLOW",
      "from": "Infective",
      "to": "Death",
      "behavior": {
        "value": "([Infective]/[Days_infected])*(([Fatality_rate])/100)",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Fatality_rate",
      "type": "VARIABLE",
      "behavior": {
        "value": "4.484",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "type": "LINK",
      "from": "Susceptible",
      "to": "to_exposed"
    },
    {
      "type": "LINK",
      "from": "initiation",
      "to": "to_exposed"
    },
    {
      "type": "LINK",
      "from": "New_cases",
      "to": "to_exposed"
    },
    {
      "type": "LINK",
      "from": "Susceptible",
      "to": "to_exposed"
    },
    {
      "type": "LINK",
      "from": "Exposed",
      "to": "to_exposed"
    },
    {
      "type": "LINK",
      "from": "Infective",
      "to": "recoveries"
    },
    {
      "type": "LINK",
      "from": "Days_infected",
      "to": "recoveries"
    },
    {
      "type": "LINK",
      "from": "Fatality_rate",
      "to": "recoveries"
    },
    {
      "type": "LINK",
      "from": "Infective",
      "to": "recoveries"
    },
    {
      "type": "LINK",
      "from": "Recovered",
      "to": "recoveries"
    },
    {
      "type": "LINK",
      "from": "Infective",
      "to": "New_cases"
    },
    {
      "type": "LINK",
      "from": "Contacts_per_day",
      "to": "New_cases"
    },
    {
      "type": "LINK",
      "from": "Infectivity",
      "to": "New_cases"
    },
    {
      "type": "LINK",
      "from": "Probability_of_meeting_a_susceptible_person",
      "to": "New_cases"
    },
    {
      "type": "LINK",
      "from": "Susceptible",
      "to": "Total_Population"
    },
    {
      "type": "LINK",
      "from": "Infective",
      "to": "Total_Population"
    },
    {
      "type": "LINK",
      "from": "Recovered",
      "to": "Total_Population"
    },
    {
      "type": "LINK",
      "from": "Exposed",
      "to": "Total_Population"
    },
    {
      "type": "LINK",
      "from": "Susceptible",
      "to": "Probability_of_meeting_a_susceptible_person"
    },
    {
      "type": "LINK",
      "from": "Total_Population",
      "to": "Probability_of_meeting_a_susceptible_person"
    },
    {
      "type": "LINK",
      "from": "Exposed",
      "to": "becoming_infectious"
    },
    {
      "type": "LINK",
      "from": "Incubation_period",
      "to": "becoming_infectious"
    },
    {
      "type": "LINK",
      "from": "Exposed",
      "to": "becoming_infectious"
    },
    {
      "type": "LINK",
      "from": "Infective",
      "to": "becoming_infectious"
    },
    {
      "type": "LINK",
      "from": "Infective",
      "to": "Fatalities"
    },
    {
      "type": "LINK",
      "from": "Days_infected",
      "to": "Fatalities"
    },
    {
      "type": "LINK",
      "from": "Fatality_rate",
      "to": "Fatalities"
    },
    {
      "type": "LINK",
      "from": "Infective",
      "to": "Fatalities"
    },
    {
      "type": "LINK",
      "from": "Death",
      "to": "Fatalities"
    }
  ],
  "engine_settings": []
}
