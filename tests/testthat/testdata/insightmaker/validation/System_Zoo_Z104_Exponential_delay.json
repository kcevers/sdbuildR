{
  "engine": "SIMULATION_PACKAGE",
  "name": "System Zoo Z104: Exponential delay",
  "simulation": {
    "version": "22",
    "time_length": "10",
    "time_start": "0",
    "time_step": "0.05",
    "time_units": "YEARS",
    "algorithm": "RK4"
  },
  "elements": [
    {
      "name": "state",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "",
        "units": "Stuff",
        "non_negative": false
      }
    },
    {
      "name": "rate_of_change",
      "type": "FLOW",
      "from": null,
      "to": "state",
      "behavior": {
        "value": "[selfgeneration]+[input_function]",
        "description": "",
        "units": "Stuff per Year",
        "non_negative": false
      }
    },
    {
      "name": "input_function",
      "type": "VARIABLE",
      "behavior": {
        "value": "[STEP_FUNCTION]*Staircase(1, 1)+[RAMP_FUNCTION]*Ramp(1, 5, 4)+[SINE_FUNCTION]*Sin(2*pi*[FREQUENCY]*Time)",
        "description": "",
        "units": "Stuff per Year"
      }
    },
    {
      "name": "STEP_FUNCTION",
      "type": "VARIABLE",
      "behavior": {
        "value": "0",
        "description": "",
        "units": "Stuff per Year"
      }
    },
    {
      "name": "SINE_FUNCTION",
      "type": "VARIABLE",
      "behavior": {
        "value": "0",
        "description": "",
        "units": "Stuff per Year"
      }
    },
    {
      "name": "RAMP_FUNCTION",
      "type": "VARIABLE",
      "behavior": {
        "value": "1",
        "description": "",
        "units": "Stuff per Year"
      }
    },
    {
      "name": "FREQUENCY",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.5",
        "description": "",
        "units": "Years^-1"
      }
    },
    {
      "name": "RATE_OF_SELFCOUPLING",
      "type": "VARIABLE",
      "behavior": {
        "value": "-0.667",
        "description": "",
        "units": "Years^-1"
      }
    },
    {
      "name": "selfgeneration",
      "type": "VARIABLE",
      "behavior": {
        "value": "[RATE_OF_SELFCOUPLING]*[state]",
        "description": "",
        "units": "Stuff per Year"
      }
    },
    {
      "type": "LINK",
      "from": "input_function",
      "to": "rate_of_change"
    },
    {
      "type": "LINK",
      "from": "selfgeneration",
      "to": "rate_of_change"
    },
    {
      "type": "LINK",
      "from": "state",
      "to": "rate_of_change"
    },
    {
      "type": "LINK",
      "from": "STEP_FUNCTION",
      "to": "input_function"
    },
    {
      "type": "LINK",
      "from": "SINE_FUNCTION",
      "to": "input_function"
    },
    {
      "type": "LINK",
      "from": "RAMP_FUNCTION",
      "to": "input_function"
    },
    {
      "type": "LINK",
      "from": "FREQUENCY",
      "to": "input_function"
    },
    {
      "type": "LINK",
      "from": "state",
      "to": "selfgeneration"
    },
    {
      "type": "LINK",
      "from": "RATE_OF_SELFCOUPLING",
      "to": "selfgeneration"
    }
  ],
  "engine_settings": {
    "units": [
      [
        {
          "name": "stuff per year",
          "factor": "1",
          "base": "stuff*years^-1"
        }
      ],
      [
        {
          "name": "stuff",
          "factor": "1",
          "base": ""
        }
      ]
    ]
  }
}
