{
  "engine": "SIMULATION_PACKAGE",
  "name": "System Zoo Z415 Resource Extraction and Recycling",
  "simulation": {
    "version": "37",
    "time_length": "125",
    "time_start": "0",
    "time_step": "0.25",
    "time_units": "YEARS",
    "algorithm": "RK1"
  },
  "elements": [
    {
      "name": "Cumulative_resource_consumption",
      "type": "STOCK",
      "behavior": {
        "initial_value": "[INITIAL_CUMULATED_CONSUMPTION]",
        "description": "",
        "units": "Mt"
      }
    },
    {
      "name": "Resource_in_use",
      "type": "STOCK",
      "behavior": {
        "initial_value": "[INITIAL_RESOURCE_DEMAND]*[PRODUCT_LIFE_time]",
        "description": "",
        "units": "Mt"
      }
    },
    {
      "name": "Resource_demand",
      "type": "STOCK",
      "behavior": {
        "initial_value": "[INITIAL_RESOURCE_DEMAND]",
        "description": "",
        "units": "Mt/Year"
      }
    },
    {
      "name": "resource_exploitation",
      "type": "FLOW",
      "from": null,
      "to": "Cumulative_resource_consumption",
      "behavior": {
        "value": "([Resource_demand]-[recycled_resource])*[supply_index]",
        "description": "",
        "units": "Mt/Year",
        "non_negative": true
      }
    },
    {
      "name": "scrapping_rate",
      "type": "FLOW",
      "from": "Resource_in_use",
      "to": null,
      "behavior": {
        "value": "[Resource_in_use]/[PRODUCT_LIFE_time]",
        "description": "",
        "units": "Mt/Year",
        "non_negative": true
      }
    },
    {
      "name": "production_rate",
      "type": "FLOW",
      "from": null,
      "to": "Resource_in_use",
      "behavior": {
        "value": "[resource_exploitation]+[recycled_resource]",
        "description": "",
        "units": "Mt/Year",
        "non_negative": true
      }
    },
    {
      "name": "growth_of_resource_demand",
      "type": "FLOW",
      "from": null,
      "to": "Resource_demand",
      "behavior": {
        "value": "([CONSUMPTION_INCREASE_TODAY]/100)*[Resource_demand]*(1-[Resource_demand]/([INITIAL_RESOURCE_DEMAND]*[MAX_DEMAND_FACTOR]))",
        "description": "",
        "units": "Mt/Year^2",
        "non_negative": true
      }
    },
    {
      "name": "ORIGINAL_RESOURCE_RESERVES",
      "type": "VARIABLE",
      "behavior": {
        "value": "100\n",
        "description": "",
        "units": "Mt"
      }
    },
    {
      "name": "RECYCLING_0_OR_1",
      "type": "VARIABLE",
      "behavior": {
        "value": "1",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "PRODUCT_LIFE_time",
      "type": "VARIABLE",
      "behavior": {
        "value": "10",
        "description": "",
        "units": "Year"
      }
    },
    {
      "name": "MAX_DEMAND_FACTOR",
      "type": "VARIABLE",
      "behavior": {
        "value": "2",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "CONSUMPTION_INCREASE_TODAY",
      "type": "VARIABLE",
      "behavior": {
        "value": "2",
        "description": "",
        "units": "1/Year"
      }
    },
    {
      "name": "INITIAL_RESOURCE_DEMAND",
      "type": "VARIABLE",
      "behavior": {
        "value": "5",
        "description": "",
        "units": "Mt/Year"
      }
    },
    {
      "name": "INITIAL_CUMULATED_CONSUMPTION",
      "type": "VARIABLE",
      "behavior": {
        "value": "0",
        "description": "",
        "units": "Mt"
      }
    },
    {
      "name": "supply_index",
      "type": "VARIABLE",
      "behavior": {
        "value": "([ORIGINAL_RESOURCE_RESERVES]-[Cumulative_resource_consumption])/[ORIGINAL_RESOURCE_RESERVES]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "resource_recycling_share",
      "type": "VARIABLE",
      "behavior": {
        "value": "Lookup([price_level], {0,1,2,5,10,15,20}, {0,0,0.2,0.6,0.85,0.95,0.95})",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "price_level",
      "type": "VARIABLE",
      "behavior": {
        "value": "If [supply_index]>0.1\n  Then \n  1/[supply_index] \nElse \n  10 \nEnd if",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "recycled_resource",
      "type": "VARIABLE",
      "behavior": {
        "value": "[scrapping_rate]*[resource_recycling_share]*[RECYCLING_0_OR_1]",
        "description": "",
        "units": "Mt/Year"
      }
    },
    {
      "type": "LINK",
      "from": "INITIAL_CUMULATED_CONSUMPTION",
      "to": "Cumulative_resource_consumption"
    },
    {
      "type": "LINK",
      "from": "PRODUCT_LIFE_time",
      "to": "Resource_in_use"
    },
    {
      "type": "LINK",
      "from": "INITIAL_RESOURCE_DEMAND",
      "to": "Resource_in_use"
    },
    {
      "type": "LINK",
      "from": "INITIAL_RESOURCE_DEMAND",
      "to": "Resource_demand"
    },
    {
      "type": "LINK",
      "from": "Resource_demand",
      "to": "resource_exploitation"
    },
    {
      "type": "LINK",
      "from": "supply_index",
      "to": "resource_exploitation"
    },
    {
      "type": "LINK",
      "from": "recycled_resource",
      "to": "resource_exploitation"
    },
    {
      "type": "LINK",
      "from": "Cumulative_resource_consumption",
      "to": "resource_exploitation"
    },
    {
      "type": "LINK",
      "from": "Resource_in_use",
      "to": "scrapping_rate"
    },
    {
      "type": "LINK",
      "from": "PRODUCT_LIFE_time",
      "to": "scrapping_rate"
    },
    {
      "type": "LINK",
      "from": "Resource_in_use",
      "to": "scrapping_rate"
    },
    {
      "type": "LINK",
      "from": "resource_exploitation",
      "to": "production_rate"
    },
    {
      "type": "LINK",
      "from": "recycled_resource",
      "to": "production_rate"
    },
    {
      "type": "LINK",
      "from": "Resource_in_use",
      "to": "production_rate"
    },
    {
      "type": "LINK",
      "from": "Resource_demand",
      "to": "growth_of_resource_demand"
    },
    {
      "type": "LINK",
      "from": "Resource_demand",
      "to": "growth_of_resource_demand"
    },
    {
      "type": "LINK",
      "from": "MAX_DEMAND_FACTOR",
      "to": "growth_of_resource_demand"
    },
    {
      "type": "LINK",
      "from": "CONSUMPTION_INCREASE_TODAY",
      "to": "growth_of_resource_demand"
    },
    {
      "type": "LINK",
      "from": "INITIAL_RESOURCE_DEMAND",
      "to": "growth_of_resource_demand"
    },
    {
      "type": "LINK",
      "from": "Resource_demand",
      "to": "growth_of_resource_demand"
    },
    {
      "type": "LINK",
      "from": "Cumulative_resource_consumption",
      "to": "supply_index"
    },
    {
      "type": "LINK",
      "from": "ORIGINAL_RESOURCE_RESERVES",
      "to": "supply_index"
    },
    {
      "type": "LINK",
      "from": "ORIGINAL_RESOURCE_RESERVES",
      "to": "supply_index"
    },
    {
      "type": "LINK",
      "from": "price_level",
      "to": "resource_recycling_share"
    },
    {
      "type": "LINK",
      "from": "supply_index",
      "to": "price_level"
    },
    {
      "type": "LINK",
      "from": "supply_index",
      "to": "price_level"
    },
    {
      "type": "LINK",
      "from": "scrapping_rate",
      "to": "recycled_resource"
    },
    {
      "type": "LINK",
      "from": "RECYCLING_0_OR_1",
      "to": "recycled_resource"
    },
    {
      "type": "LINK",
      "from": "resource_recycling_share",
      "to": "recycled_resource"
    }
  ],
  "engine_settings": []
}
