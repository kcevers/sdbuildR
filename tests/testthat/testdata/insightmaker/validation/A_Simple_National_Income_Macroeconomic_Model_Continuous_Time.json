{
  "engine": "SIMULATION_PACKAGE",
  "name": "A Simple National Income Macroeconomic Model Continuous Time",
  "simulation": {
    "version": "36",
    "time_length": "5",
    "time_start": "0",
    "time_step": "0.5",
    "time_units": "YEARS",
    "algorithm": "RK1"
  },
  "elements": [
    {
      "name": "I",
      "type": "VARIABLE",
      "behavior": {
        "value": "0",
        "description": "Investment expenditure ",
        "units": "Unitless"
      }
    },
    {
      "name": "Government_expenditure_Go",
      "type": "VARIABLE",
      "behavior": {
        "value": "-100",
        "description": "Government expenditure at time 0, default is -100",
        "units": "Unitless"
      }
    },
    {
      "name": "Marginal_Propensity_to_Consume_c",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.8",
        "description": "default is 0,8",
        "units": "Unitless"
      }
    },
    {
      "name": "Consumption_Co",
      "type": "VARIABLE",
      "behavior": {
        "value": "100",
        "description": "Co is the Consumption that occurs when there is no income, default 100",
        "units": "Unitless"
      }
    },
    {
      "name": "Income_Yo",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Consumption_Co]+[I]+[Government_expenditure_Go]",
        "description": "inital value 0",
        "units": "Unitless"
      }
    },
    {
      "name": "Consumption_Ci",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Consumption_Co]+([Marginal_Propensity_to_Consume_c]*[Income_Yi])",
        "description": "Ci is the Consumption that occurs at time i ",
        "units": "Unitless"
      }
    },
    {
      "name": "Income_Yi",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Income_Yo]+([DeltaG]/(1-[Marginal_Propensity_to_Consume_c]))",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Government_expenditure_Gi",
      "type": "VARIABLE",
      "behavior": {
        "value": "-20",
        "description": "Government expenditure at time i, default is -20",
        "units": "Unitless"
      }
    },
    {
      "name": "DeltaG",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Government_expenditure_Gi]-[Government_expenditure_Go]",
        "description": "default is 80",
        "units": "Unitless"
      }
    },
    {
      "name": "Consumption_C",
      "type": "STOCK",
      "behavior": {
        "initial_value": "[Consumption_Co]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Government_Expenditure_G",
      "type": "STOCK",
      "behavior": {
        "initial_value": "[Government_expenditure_Go]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Income_Y",
      "type": "STOCK",
      "behavior": {
        "initial_value": "[Income_Yo]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Flow",
      "type": "FLOW",
      "from": null,
      "to": "Government_Expenditure_G",
      "behavior": {
        "value": "[DeltaG]",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Flow_1",
      "type": "FLOW",
      "from": null,
      "to": "Income_Y",
      "behavior": {
        "value": "[deltaY]",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Flow_2",
      "type": "FLOW",
      "from": null,
      "to": "Consumption_C",
      "behavior": {
        "value": "[deltaC]",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "deltaC",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Marginal_Propensity_to_Consume_c]*[deltaY]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "deltaY",
      "type": "VARIABLE",
      "behavior": {
        "value": "[DeltaG]/(1-[Marginal_Propensity_to_Consume_c])",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "type": "LINK",
      "from": "I",
      "to": "Income_Yo"
    },
    {
      "type": "LINK",
      "from": "Government_expenditure_Go",
      "to": "Income_Yo"
    },
    {
      "type": "LINK",
      "from": "Consumption_Co",
      "to": "Income_Yo"
    },
    {
      "type": "LINK",
      "from": "Marginal_Propensity_to_Consume_c",
      "to": "Consumption_Ci"
    },
    {
      "type": "LINK",
      "from": "Consumption_Co",
      "to": "Consumption_Ci"
    },
    {
      "type": "LINK",
      "from": "Income_Yi",
      "to": "Consumption_Ci"
    },
    {
      "type": "LINK",
      "from": "Marginal_Propensity_to_Consume_c",
      "to": "Income_Yi"
    },
    {
      "type": "LINK",
      "from": "Income_Yo",
      "to": "Income_Yi"
    },
    {
      "type": "LINK",
      "from": "DeltaG",
      "to": "Income_Yi"
    },
    {
      "type": "LINK",
      "from": "Government_expenditure_Go",
      "to": "DeltaG"
    },
    {
      "type": "LINK",
      "from": "Government_expenditure_Gi",
      "to": "DeltaG"
    },
    {
      "type": "LINK",
      "from": "Consumption_Co",
      "to": "Consumption_C"
    },
    {
      "type": "LINK",
      "from": "Government_expenditure_Go",
      "to": "Government_Expenditure_G"
    },
    {
      "type": "LINK",
      "from": "Income_Yo",
      "to": "Income_Y"
    },
    {
      "type": "LINK",
      "from": "DeltaG",
      "to": "Flow"
    },
    {
      "type": "LINK",
      "from": "Government_Expenditure_G",
      "to": "Flow"
    },
    {
      "type": "LINK",
      "from": "deltaY",
      "to": "Flow_1"
    },
    {
      "type": "LINK",
      "from": "Income_Y",
      "to": "Flow_1"
    },
    {
      "type": "LINK",
      "from": "deltaC",
      "to": "Flow_2"
    },
    {
      "type": "LINK",
      "from": "Consumption_C",
      "to": "Flow_2"
    },
    {
      "type": "LINK",
      "from": "Marginal_Propensity_to_Consume_c",
      "to": "deltaC"
    },
    {
      "type": "LINK",
      "from": "deltaY",
      "to": "deltaC"
    },
    {
      "type": "LINK",
      "from": "Marginal_Propensity_to_Consume_c",
      "to": "deltaY"
    },
    {
      "type": "LINK",
      "from": "DeltaG",
      "to": "deltaY"
    }
  ],
  "engine_settings": []
}
