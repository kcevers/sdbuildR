        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "d13",
      "type": "FLOW",
      "from": "mid_range_sink",
      "to": "SOURCE",
      "behavior": {
        "value": "disp<-[Max_disp_rate]*[mid_range_sink]*0.25-[Max_disp_rate]*[SOURCE]*0.25\nIf disp>=0 Then\n  RandPoisson(disp+0.00001)\nElse\n  -1*RandPoisson(-1*disp)\nEnd If",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "d24",
      "type": "FLOW",
      "from": "distant_sink",
      "to": "nearby_sink",
      "behavior": {
        "value": "disp <- [Max_disp_rate]*[distant_sink]*0.05-[Max_disp_rate]*[nearby_sink]*0.05\nIf disp>=0 Then\n  RandPoisson(disp+0.00001)\nElse\n  -1*RandPoisson(-1*disp)\nEnd If",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
