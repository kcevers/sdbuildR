{
  "engine": "SIMULATION_PACKAGE",
  "name": "Bossel: Z110: Logistic growth with stock-dependent harvest",
  "simulation": {
    "version": "37",
    "time_length": "20",
    "time_start": "0",
    "time_step": "0.2",
    "time_units": "YEARS",
    "algorithm": "RK4"
  },
  "elements": [
    {
      "name": "stock_1",
      "type": "STOCK",
      "behavior": {
        "initial_value": "[INITIAL_STOCK]",
        "description": "",
        "units": "Stuff",
        "non_negative": false
      }
    },
    {
      "name": "increase",
      "type": "FLOW",
      "from": null,
      "to": "stock_1",
      "behavior": {
        "value": "[MAX_GROWTH_RATE]*[stock_1]*(1-[stock_1]/[CARRYING_CAPACITY])",
        "description": "",
        "units": "Stuff per Year",
        "non_negative": true
      }
    },
    {
      "name": "harvest",
      "type": "FLOW",
      "from": "stock_1",
      "to": null,
      "behavior": {
        "value": "[HARVEST_RATE]*[stock_1]",
