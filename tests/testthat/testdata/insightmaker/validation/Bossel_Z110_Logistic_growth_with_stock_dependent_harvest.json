    {
      "name": "HARVEST_RATE",
      "type": "VARIABLE",
      "behavior": {
        "value": "0",
        "description": "",
        "units": "Years^-1"
      }
    },
    {
      "name": "INITIAL_STOCK",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.01",
        "description": "",
        "units": "Stuff"
      }
    },
    {
      "name": "net_growth",
      "type": "VARIABLE",
      "behavior": {
        "value": "0",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "type": "LINK",
      "from": "INITIAL_STOCK",
      "to": "stock_1"
    },
    {
      "type": "LINK",
      "from": "stock_1",
      "to": "increase"
    },
    {
      "type": "LINK",
      "from": "stock_1",
      "to": "increase"
    },
    {
      "type": "LINK",
      "from": "MAX_GROWTH_RATE",
      "to": "increase"
    },
    {
      "type": "LINK",
      "from": "CARRYING_CAPACITY",
      "to": "increase"
    },
    {
      "type": "LINK",
      "from": "stock_1",
      "to": "increase"
    },
    {
      "type": "LINK",
      "from": "stock_1",
      "to": "harvest"
    },
    {
      "type": "LINK",
      "from": "HARVEST_RATE",
      "to": "harvest"
    },
    {
      "type": "LINK",
      "from": "stock_1",
      "to": "harvest"
    }
