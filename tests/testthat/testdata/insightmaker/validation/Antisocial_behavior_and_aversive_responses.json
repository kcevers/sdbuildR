{
  "engine": "SIMULATION_PACKAGE",
  "name": "Antisocial behavior and aversive responses",
  "simulation": {
    "version": "37",
    "time_length": "300",
    "time_start": "0",
    "time_step": "1",
    "time_units": "MONTHS",
    "algorithm": "RK4"
  },
  "elements": [
    {
      "name": "Anti_Social_Behaviour",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0.01",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Aversive_Action",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0.01",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "ASB_rate_of_increase",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.27",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "ASB_decrease_rate",
      "type": "VARIABLE",
      "behavior": {
        "value": "1.07",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "AA_rate_of_increase",
      "type": "VARIABLE",
      "behavior": {
        "value": "1.5",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "AA_rate_of_decrease",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.2",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "decrease_ASB",
      "type": "FLOW",
      "from": "Anti_Social_Behaviour",
      "to": null,
      "behavior": {
        "value": "([ASB_decrease_rate]*[Aversive_Action])*[Anti_Social_Behaviour]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "increase_ASB",
      "type": "FLOW",
      "from": null,
      "to": "Anti_Social_Behaviour",
      "behavior": {
        "value": "[Anti_Social_Behaviour]*[ASB_rate_of_increase]*(1-[Anti_Social_Behaviour]/[Limit_antisocial_behavior])+RandNormal(0, [variation])+[unforeseen_event]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "AA_decrease",
      "type": "FLOW",
      "from": "Aversive_Action",
      "to": null,
      "behavior": {
        "value": "[AA_rate_of_decrease]*[Aversive_Action]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "AA_increase",
      "type": "FLOW",
      "from": null,
      "to": "Aversive_Action",
      "behavior": {
        "value": "([AA_rate_of_increase]*[Anti_Social_Behaviour])*[Aversive_Action]+RandNormal(0, [variation])",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "AA_limit",
      "type": "VARIABLE",
      "behavior": {
        "value": "1",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Limit_antisocial_behavior",
      "type": "STOCK",
      "behavior": {
        "initial_value": "1",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Growth_rate_limit",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.047",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "diminution_limit",
      "type": "FLOW",
      "from": "Limit_antisocial_behavior",
      "to": null,
      "behavior": {
        "value": "[Decrease_rate_limit]*[Limit_antisocial_behavior]+RandNormal(0, [variation])",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Growth_limit",
      "type": "FLOW",
      "from": null,
      "to": "Limit_antisocial_behavior",
      "behavior": {
        "value": "[Growth_rate_limit]*[Limit_antisocial_behavior]*[Aversive_Action]+(RandNormal(0, [variation]))",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Decrease_rate_limit",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.01",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "variation",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.01",
        "description": "To show the effect of random influences on the variables, try values between 0.05 and 0.1.",
        "units": "Unitless"
      }
    },
    {
      "name": "unforeseen_event",
      "type": "VARIABLE",
      "behavior": {
        "value": "(RandNormal(0, [random_influence]))",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "random_influence",
      "type": "VARIABLE",
      "behavior": {
        "value": "IfThenElse(Time()>{150 Months} AND Time()<{160 Months}, [i_a], 0)",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "i_a",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.51",
        "description": "To show an unexpected event, change this parameter to 0.5 (plus or minus). To remove the effect of an unexpected event, change the parameter to 0 (zero).",
        "units": "Unitless"
      }
    },
    {
      "type": "LINK",
      "from": "Anti_Social_Behaviour",
      "to": "decrease_ASB"
    },
    {
      "type": "LINK",
      "from": "Aversive_Action",
      "to": "decrease_ASB"
    },
    {
      "type": "LINK",
      "from": "ASB_decrease_rate",
      "to": "decrease_ASB"
    },
    {
      "type": "LINK",
      "from": "Anti_Social_Behaviour",
      "to": "decrease_ASB"
    },
    {
      "type": "LINK",
      "from": "Anti_Social_Behaviour",
      "to": "increase_ASB"
    },
    {
      "type": "LINK",
      "from": "Anti_Social_Behaviour",
      "to": "increase_ASB"
    },
    {
      "type": "LINK",
      "from": "ASB_rate_of_increase",
      "to": "increase_ASB"
    },
    {
      "type": "LINK",
      "from": "Limit_antisocial_behavior",
      "to": "increase_ASB"
    },
    {
      "type": "LINK",
      "from": "variation",
      "to": "increase_ASB"
    },
    {
      "type": "LINK",
      "from": "unforeseen_event",
      "to": "increase_ASB"
    },
    {
      "type": "LINK",
      "from": "Anti_Social_Behaviour",
      "to": "increase_ASB"
    },
    {
      "type": "LINK",
      "from": "Aversive_Action",
      "to": "AA_decrease"
    },
    {
      "type": "LINK",
      "from": "AA_rate_of_decrease",
      "to": "AA_decrease"
    },
    {
      "type": "LINK",
      "from": "Aversive_Action",
      "to": "AA_decrease"
    },
    {
      "type": "LINK",
      "from": "Anti_Social_Behaviour",
      "to": "AA_increase"
    },
    {
      "type": "LINK",
      "from": "Aversive_Action",
      "to": "AA_increase"
    },
    {
      "type": "LINK",
      "from": "AA_rate_of_increase",
      "to": "AA_increase"
    },
    {
      "type": "LINK",
      "from": "variation",
      "to": "AA_increase"
    },
    {
      "type": "LINK",
      "from": "Aversive_Action",
      "to": "AA_increase"
    },
    {
      "type": "LINK",
      "from": "Limit_antisocial_behavior",
      "to": "diminution_limit"
    },
    {
      "type": "LINK",
      "from": "Decrease_rate_limit",
      "to": "diminution_limit"
    },
    {
      "type": "LINK",
      "from": "variation",
      "to": "diminution_limit"
    },
    {
      "type": "LINK",
      "from": "Limit_antisocial_behavior",
      "to": "diminution_limit"
    },
    {
      "type": "LINK",
      "from": "Aversive_Action",
      "to": "Growth_limit"
    },
    {
      "type": "LINK",
      "from": "Limit_antisocial_behavior",
      "to": "Growth_limit"
    },
    {
      "type": "LINK",
      "from": "Growth_rate_limit",
      "to": "Growth_limit"
    },
    {
      "type": "LINK",
      "from": "variation",
      "to": "Growth_limit"
    },
    {
      "type": "LINK",
      "from": "Limit_antisocial_behavior",
      "to": "Growth_limit"
    },
    {
      "type": "LINK",
      "from": "random_influence",
      "to": "unforeseen_event"
    },
    {
      "type": "LINK",
      "from": "i_a",
      "to": "random_influence"
    }
  ],
  "engine_settings": []
}
