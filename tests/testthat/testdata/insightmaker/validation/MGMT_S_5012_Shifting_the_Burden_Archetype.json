{
  "engine": "SIMULATION_PACKAGE",
  "name": "MGMT S-5012 - Shifting the Burden Archetype",
  "simulation": {
    "version": "36",
    "time_length": "10",
    "time_start": "0",
    "time_step": "0.25",
    "time_units": "MONTHS",
    "algorithm": "RK1"
  },
  "elements": [
    {
      "name": "Problem_Symptom",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "This is the problem symptom that needs to be removed.",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "symptomatic_solution",
      "type": "FLOW",
      "from": "Problem_Symptom",
      "to": null,
      "behavior": {
        "value": "IfThenElse([Problem_Symptom]>.8, 10, 0)*[sym_fact]",
        "description": "The symptomatic action, which is a function of the problem symptom, serves to reduce the problem symptom.",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "sym_fact",
      "type": "VARIABLE",
      "behavior": {
        "value": ".5",
        "description": "This is just an adjustment factor to control the rate at which the symptomatic action reduces the problem symptom.",
        "units": "Unitless"
      }
    },
    {
      "name": "problem_cause",
      "type": "FLOW",
      "from": null,
      "to": "Problem_Symptom",
      "behavior": {
        "value": "[prob_fact]-[Fundamental_Solution]",
        "description": "This represents the real cause of the problem. If one stops applying the symptomatic solution the problem symptom will continue to grow.",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Fundamental_Solution",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "This is the longer term solution that will actually remove the cause of the problem.",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "fundamental_action",
      "type": "FLOW",
      "from": null,
      "to": "Fundamental_Solution",
      "behavior": {
        "value": "([Problem_Symptom]-[Side_Effect])*[fund_fact]",
        "description": "The build up of the fundamental solution.",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "prob_fact",
      "type": "VARIABLE",
      "behavior": {
        "value": ".5",
        "description": "This is just an adjustment factor to control the rate at which the problem cause adds to the problem symptom.",
        "units": "Unitless"
      }
    },
    {
      "name": "fund_fact",
      "type": "VARIABLE",
      "behavior": {
        "value": ".2",
        "description": "This is just an adjustment factor to control the rate at which the fundamental action adds to the fundamental solution.",
        "units": "Unitless"
      }
    },
    {
      "name": "side_effect_fact",
      "type": "VARIABLE",
      "behavior": {
        "value": ".2",
        "description": "A factor to control the extent to which application of the symptomatic solution influences  Side Effect growth.",
        "units": "Unitless"
      }
    },
    {
      "name": "Side_Effect",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "se_inflow",
      "type": "FLOW",
      "from": null,
      "to": "Side_Effect",
      "behavior": {
        "value": "[symptomatic_solution]*[side_effect_fact]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "symptomatic_solution_1",
      "type": "VARIABLE",
      "behavior": {
        "value": "0",
        "description": "The symptomatic solution is generally more quickly effected thus reducing the awareness of the problem symptom.",
        "units": "Unitless"
      }
    },
    {
      "name": "fundamental_solution",
      "type": "VARIABLE",
      "behavior": {
        "value": "0",
        "description": "The fundamental solution is generally one which requires a far greater investment of time and resources to effect, though when effected it actually solves the problem removing the problem symptom and ensuring it doesn't return.",
        "units": "Unitless"
      }
    },
    {
      "name": "problem_symptom",
      "type": "VARIABLE",
      "behavior": {
        "value": "0",
        "description": "We begin with the symptom of a problem for which there is a quick solution and a longer term more involved solution.",
        "units": "Unitless"
      }
    },
    {
      "name": "side_effect",
      "type": "VARIABLE",
      "behavior": {
        "value": "0",
        "description": "After some delay employing the symptomatic solution tends promote a side effect which actually reduces the tendency to effect the fundamental solution.",
        "units": "Unitless"
      }
    },
    {
      "type": "LINK",
      "from": "Problem_Symptom",
      "to": "symptomatic_solution"
    },
    {
      "type": "LINK",
      "from": "sym_fact",
      "to": "symptomatic_solution"
    },
    {
      "type": "LINK",
      "from": "Problem_Symptom",
      "to": "symptomatic_solution"
    },
    {
      "type": "LINK",
      "from": "Fundamental_Solution",
      "to": "problem_cause"
    },
    {
      "type": "LINK",
      "from": "prob_fact",
      "to": "problem_cause"
    },
    {
      "type": "LINK",
      "from": "Problem_Symptom",
      "to": "problem_cause"
    },
    {
      "type": "LINK",
      "from": "Problem_Symptom",
      "to": "fundamental_action"
    },
    {
      "type": "LINK",
      "from": "fund_fact",
      "to": "fundamental_action"
    },
    {
      "type": "LINK",
      "from": "Side_Effect",
      "to": "fundamental_action"
    },
    {
      "type": "LINK",
      "from": "Fundamental_Solution",
      "to": "fundamental_action"
    },
    {
      "type": "LINK",
      "from": "symptomatic_solution",
      "to": "se_inflow"
    },
    {
      "type": "LINK",
      "from": "side_effect_fact",
      "to": "se_inflow"
    },
    {
      "type": "LINK",
      "from": "Side_Effect",
      "to": "se_inflow"
    }
  ],
  "engine_settings": []
}
