{
  "engine": "SIMULATION_PACKAGE",
  "name": "Dependence",
  "simulation": {
    "version": "36",
    "time_length": "50",
    "time_start": "0",
    "time_step": "0.5",
    "time_units": "MONTHS",
    "algorithm": "RK1"
  },
  "elements": [
    {
      "name": "Self_help_capacity",
      "type": "STOCK",
      "behavior": {
        "initial_value": "1",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "erodes",
      "type": "FLOW",
      "from": "Self_help_capacity",
      "to": null,
      "behavior": {
        "value": "[erosion_rate]*[Self_help_capacity]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "builds_up",
      "type": "FLOW",
      "from": null,
      "to": "Self_help_capacity",
      "behavior": {
        "value": "[build_up_rate]*[Self_help_capacity]*(1-[outside_help_share])*[Gap]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "erosion_rate",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.2",
        "description": "per month",
        "units": "Unitless"
      }
    },
    {
      "name": "build_up_rate",
      "type": "VARIABLE",
      "behavior": {
        "value": "1",
        "description": "",
        "units": "Unitless"
      }
    },
    {
