        "value": "[Self_help_effectiveness]*[Self_help_capacity]*(1-[outside_help_share])*[Gap]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "decrease",
      "type": "FLOW",
