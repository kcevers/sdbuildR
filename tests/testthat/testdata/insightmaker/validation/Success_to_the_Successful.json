{
  "engine": "SIMULATION_PACKAGE",
  "name": "Success to the Successful",
  "simulation": {
    "version": "37",
    "time_length": "10",
    "time_start": "0",
    "time_step": "1",
    "time_units": "YEARS",
    "algorithm": "RK1"
  },
  "elements": [
    {
      "name": "Allocation_to_B_Instead_of_A",
      "type": "VARIABLE",
      "behavior": {
        "value": "0",
        "description": "As long as A and B are equally successful everything will remain stable. Though if A or B receive more resources than the other or A or B is more successful than the other the imbalance will result in greater success of a or b accordingly and promote even more success of the one that demonstrates greater success.",
        "units": "Unitless"
      }
    },
    {
      "name": "success_a",
      "type": "STOCK",
      "behavior": {
        "initial_value": ".1",
        "description": "The success of a initially set to .1",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "success_b",
      "type": "STOCK",
      "behavior": {
        "initial_value": ".1",
        "description": "The success of b initially set to .1",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "action_b",
      "type": "FLOW",
      "from": null,
      "to": "success_b",
      "behavior": {
        "value": "[allocation_to_b]+[pulse_1]* Pulse([when], 1, 1)",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "action_a",
      "type": "FLOW",
      "from": null,
      "to": "success_a",
      "behavior": {
        "value": "[allocation_to_a]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "allocation_to_a",
      "type": "VARIABLE",
      "behavior": {
        "value": "1-[alloc_var]",
        "description": "The allocation to a's action which greater by a factor of alloc if success a > success b.",
        "units": "Unitless"
      }
    },
    {
      "name": "allocation_to_b",
      "type": "VARIABLE",
      "behavior": {
        "value": "1+[alloc_var]",
        "description": "The allocation to b's action which is alloc larger if success b > success a.",
        "units": "Unitless"
      }
    },
    {
      "name": "alloc_var",
      "type": "VARIABLE",
      "behavior": {
        "value": "([success_b]-[success_a])*[factor]",
        "description": "What's the allocation variance based on one being more successful than the other?",
        "units": "Unitless"
      }
    },
    {
      "name": "factor",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.4",
        "description": "The allocation to b's action which is alloc larger if success b > success a.",
        "units": "Unitless"
      }
    },
    {
      "name": "when",
      "type": "VARIABLE",
      "behavior": {
        "value": "4",
        "description": "When should the pulse be applied to improve b's performance?",
        "units": "Unitless"
      }
    },
    {
      "name": "pulse_1",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.4",
        "description": "Should a pulse be applied to create an improvement to b's performance?",
        "units": "Unitless"
      }
    },
    {
      "type": "LINK",
      "from": "allocation_to_b",
      "to": "action_b"
    },
    {
      "type": "LINK",
      "from": "when",
      "to": "action_b"
    },
    {
      "type": "LINK",
      "from": "pulse_1",
      "to": "action_b"
    },
    {
      "type": "LINK",
      "from": "success_b",
      "to": "action_b"
    },
    {
      "type": "LINK",
      "from": "allocation_to_a",
      "to": "action_a"
    },
    {
      "type": "LINK",
      "from": "success_a",
      "to": "action_a"
    },
    {
      "type": "LINK",
      "from": "alloc_var",
      "to": "allocation_to_a"
    },
    {
      "type": "LINK",
      "from": "alloc_var",
      "to": "allocation_to_b"
    },
    {
      "type": "LINK",
      "from": "success_a",
      "to": "alloc_var"
    },
    {
      "type": "LINK",
      "from": "success_b",
      "to": "alloc_var"
    },
    {
      "type": "LINK",
      "from": "factor",
      "to": "alloc_var"
    }
  ],
  "engine_settings": []
}
