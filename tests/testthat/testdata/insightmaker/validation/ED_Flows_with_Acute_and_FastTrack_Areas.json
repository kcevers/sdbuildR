        "value": "[FT_Spaces]-[FT_Care]-[FT_Care_4_]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "FT_delay_time",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.8",
        "description": "",
