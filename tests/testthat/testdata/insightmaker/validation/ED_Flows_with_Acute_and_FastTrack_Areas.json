    {
      "name": "FT_Spaces",
      "type": "VARIABLE",
      "behavior": {
        "value": "22",
        "description": "the maximum is flexible when overcrowded and includes resusc for now",
        "units": "Unitless"
      }
    },
    {
      "name": "Unoccupied_FT_spaces",
      "type": "VARIABLE",
