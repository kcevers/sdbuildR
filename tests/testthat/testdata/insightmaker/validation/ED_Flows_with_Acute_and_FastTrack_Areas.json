{
  "engine": "SIMULATION_PACKAGE",
  "name": "ED Flows with Acute and FastTrack Areas",
  "simulation": {
    "version": "36",
    "time_length": "40",
    "time_start": "8",
    "time_step": "0.25",
    "time_units": "HOURS",
    "algorithm": "RK1"
  },
  "elements": [
    {
      "name": "Ac_discharge",
      "type": "FLOW",
      "from": "Acute_Disposition",
      "to": "Recent_ED_Discharge",
      "behavior": {
        "value": "[Acute_Disposition]*(1-[Ac_admit_fraction])",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "A_disc_late",
      "type": "FLOW",
      "from": "Ac_Disp_Late",
      "to": "Recent_ED_Discharge",
      "behavior": {
        "value": "[Ac_Disp_Late]*(1-[admit_fraction_for_Ac_late])",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Pre_Triage",
      "type": "STOCK",
      "behavior": {
        "initial_value": "1",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "arrive",
      "type": "FLOW",
      "from": null,
      "to": "Pre_Triage",
      "behavior": {
        "value": "[Daily_arrivals]*[Arrival_fraction]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "triage_and_register",
      "type": "FLOW",
      "from": "Pre_Triage",
      "to": "Delay_for_Area__or_EDMO",
      "behavior": {
        "value": "12",
        "description": "quick less than 5 minutes",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Delay_for_Area__or_EDMO",
      "type": "STOCK",
      "behavior": {
        "initial_value": "1",
        "description": "lying or sitting in an ambulance bay, waiting room, or in a ED area waiting to be seen by an EDMO",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "see_in_FT",
      "type": "FLOW",
      "from": "Delay_for_Area__or_EDMO",
      "to": "FT_Care",
      "behavior": {
        "value": "IfThenElse([Unoccupied_FT_spaces]>0,  [Delay_for_Area__or_EDMO]/[FT_delay_time], 0)",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Inpatient_ward",
      "type": "STOCK",
      "behavior": {
        "initial_value": "180",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Recent_ED_Discharge",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "ED_Admitted",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "FT_admit",
      "type": "FLOW",
      "from": "FT_Disposition",
      "to": "ED_Admitted",
      "behavior": {
        "value": "[FT_Disposition]*[FTadmit_fraction]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "FT_Disposition",
      "type": "STOCK",
      "behavior": {
        "initial_value": "1",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "FT_discharge",
      "type": "FLOW",
      "from": "FT_Disposition",
      "to": "Recent_ED_Discharge",
      "behavior": {
        "value": "[FT_Disposition]*(1-[FTadmit_fraction])",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "failure_to_see",
      "type": "FLOW",
      "from": "Delay_for_Area__or_EDMO",
      "to": null,
      "behavior": {
        "value": "14/40",
        "description": "includes DidNotWait, Transfers and Treatment INcomplete (Left Against Medical Advice usually while waiting for IP Review)",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "ED_to_IPW",
      "type": "FLOW",
      "from": "ED_Admitted",
      "to": "Inpatient_ward",
      "behavior": {
        "value": "IfThenElse([Admitted_in_ED_spaces]=1,IfThenElse([occupancy_level]<0, [ED_Admitted], 0),0)",
        "description": "added ward occupancy from 7981",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "to_EMU",
      "type": "FLOW",
      "from": "ED_Admitted",
      "to": "EMU",
      "behavior": {
        "value": "IfThenElse([Admitted_in_ED_spaces]=1,IfThenElse([Unoccupied_EMU_beds]>0,  0.5, 0),0)\n",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "ward_net_discharge",
      "type": "FLOW",
      "from": "Inpatient_ward",
      "to": null,
      "behavior": {
        "value": "1.5",
        "description": "need by day and time including % before 1200 and discharges vs admits to captur readmits within 28 days",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "EMU_to_wards",
      "type": "FLOW",
      "from": "EMU",
      "to": "Inpatient_ward",
      "behavior": {
        "value": "0.025",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "EMU_to_wards_late",
      "type": "FLOW",
      "from": "EMU_1_",
      "to": "Inpatient_ward",
      "behavior": {
        "value": "0.0125",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "FT_Disp_Late",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "FTd_late",
      "type": "FLOW",
      "from": "FT_Disp_Late",
      "to": "Recent_ED_Discharge",
      "behavior": {
        "value": "[FT_Disp_Late]*(1-[admit_fraction_forFT_late])",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "FT_adm_late",
      "type": "FLOW",
      "from": "FT_Disp_Late",
      "to": "ED_Admitted",
      "behavior": {
        "value": "[FT_Disp_Late]*[admit_fraction_forFT_late]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "FTcl_to_dl",
      "type": "FLOW",
      "from": "FT_Care_4_",
      "to": "FT_Disp_Late",
      "behavior": {
        "value": "[FT_Care_4_]/[hours_beyond_target]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "FT_to_disp",
      "type": "FLOW",
      "from": "FT_Care",
      "to": "FT_Disposition",
      "behavior": {
        "value": "Min([FT_Care],[FT_completion_rate])",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "FT_Care",
      "type": "STOCK",
      "behavior": {
        "initial_value": "15",
        "description": "can be split into special areas like paeds subacute psych and procedure rooms",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "FT_Care_4_",
      "type": "STOCK",
      "behavior": {
        "initial_value": "2",
        "description": "can be split into special areas like paeds subacute psych and procedure rooms",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "X4hr_FT",
      "type": "FLOW",
      "from": "FT_Care",
      "to": "FT_Care_4_",
      "behavior": {
        "value": "[FT_Care]/[time_left_for_care]",
        "description": "add 2 and 3 hour as well esp during midshift eg 8-1400 and 1600 to 2000",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "EMU",
      "type": "STOCK",
      "behavior": {
        "initial_value": "5",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "EMU_1_",
      "type": "STOCK",
      "behavior": {
        "initial_value": "1",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "X24hrs",
      "type": "FLOW",
      "from": "EMU",
      "to": "EMU_1_",
      "behavior": {
        "value": "0.025",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "EMU_discharge",
      "type": "FLOW",
      "from": "EMU",
      "to": null,
      "behavior": {
        "value": "0.45",
        "description": "90%",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "EMU_discharge_late",
      "type": "FLOW",
      "from": "EMU_1_",
      "to": null,
      "behavior": {
        "value": "0.0125",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "FT_completion_rate",
      "type": "VARIABLE",
      "behavior": {
        "value": "[base_completion_rate]+[specialists_per_hour]*[specialist_effect_on_FT]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Arrival_fraction",
      "type": "CONVERTER",
      "behavior": {
        "input": "ELEMENT",
        "input_element": "Hour_of_day",
        "interpolation": "LINEAR",
        "data": [
            [0, 0.031],
            [1, 0.029],
            [2, 0.026],
            [3, 0.023],
            [4, 0.02],
            [5, 0.018],
            [6, 0.018],
            [7, 0.026],
            [8, 0.037],
            [9, 0.051],
            [10, 0.059],
            [11, 0.062],
            [12, 0.061],
            [13, 0.059],
            [14, 0.057],
            [15, 0.056],
            [16, 0.054],
