{
  "engine": "SIMULATION_PACKAGE",
  "name": "basic warehouse stock control",
  "simulation": {
    "version": "27",
    "time_length": "200",
    "time_start": "0",
    "time_step": "1",
    "time_units": "DAYS",
    "algorithm": "RK1"
  },
  "elements": [
    {
      "name": "our_warehouse",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "lower_limit",
      "type": "VARIABLE",
      "behavior": {
        "value": "21.1",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "demand",
      "type": "VARIABLE",
      "behavior": {
        "value": "RandNormal(10, 20)",
        "description": "that is what we need to examine to control input flow",
        "units": "Unitless"
      }
    },
    {
      "name": "customers_consumption",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "supliers_warehouse",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "input_Flow",
      "type": "FLOW",
      "from": "supliers_warehouse",
      "to": "our_warehouse",
      "behavior": {
        "value": "IfThenElse([our_warehouse]<[lower_limit], [upper_limit]-[our_warehouse], 0)",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "output_Flow",
      "type": "FLOW",
      "from": "our_warehouse",
      "to": "customers_consumption",
      "behavior": {
        "value": "IfThenElse([demand]<0, 0, [demand])",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "upper_limit",
      "type": "VARIABLE",
      "behavior": {
        "value": "146.8",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "unsatisfired_demand",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "virtual_negative_Flow",
      "type": "FLOW",
      "from": "our_warehouse",
      "to": "unsatisfired_demand",
      "behavior": {
        "value": "IfThenElse([our_warehouse]<0,Abs( [our_warehouse]), 0)",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "type": "LINK",
      "from": "our_warehouse",
      "to": "input_Flow"
    },
    {
      "type": "LINK",
      "from": "our_warehouse",
      "to": "input_Flow"
    },
    {
      "type": "LINK",
      "from": "lower_limit",
      "to": "input_Flow"
    },
    {
      "type": "LINK",
      "from": "upper_limit",
      "to": "input_Flow"
    },
    {
      "type": "LINK",
      "from": "supliers_warehouse",
      "to": "input_Flow"
    },
    {
      "type": "LINK",
      "from": "our_warehouse",
      "to": "input_Flow"
    },
    {
      "type": "LINK",
      "from": "demand",
      "to": "output_Flow"
    },
    {
      "type": "LINK",
      "from": "demand",
      "to": "output_Flow"
    },
    {
      "type": "LINK",
      "from": "our_warehouse",
      "to": "output_Flow"
    },
    {
      "type": "LINK",
      "from": "customers_consumption",
      "to": "output_Flow"
    },
    {
      "type": "LINK",
      "from": "our_warehouse",
      "to": "virtual_negative_Flow"
    },
    {
      "type": "LINK",
      "from": "our_warehouse",
      "to": "virtual_negative_Flow"
    },
    {
      "type": "LINK",
      "from": "our_warehouse",
      "to": "virtual_negative_Flow"
    },
    {
      "type": "LINK",
      "from": "unsatisfired_demand",
      "to": "virtual_negative_Flow"
    }
  ],
  "engine_settings": []
}
