{
  "engine": "SIMULATION_PACKAGE",
  "name": "Diffusion of Innovation Bass Model",
  "simulation": {
    "version": "36",
    "time_length": "10",
    "time_start": "0",
    "time_step": "0.0625",
    "time_units": "YEARS",
    "algorithm": "RK1"
  },
  "elements": [
    {
      "name": "Potential_Adopters",
      "type": "STOCK",
      "behavior": {
        "initial_value": "100000",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Adopters",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "adoption_rate",
      "type": "FLOW",
      "from": "Potential_Adopters",
      "to": "Adopters",
      "behavior": {
        "value": "[Adoption_from_advertising]+[Adoption_from_word_of_mouth]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Adoption_from_advertising",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Advertising_effectiveness_per_year]*[Potential_Adopters]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Adoption_from_word_of_mouth",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Adopters]*[Probability_of_contacting_a_potential_adopter]*[Contact_rate_per_year]*[Adoption_fraction_per_contact]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Advertising_effectiveness_per_year",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.2",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Total_population",
      "type": "VARIABLE",
      "behavior": {
        "value": "150000",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Adoption_fraction_per_contact",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.2",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Contact_rate_per_year",
      "type": "VARIABLE",
      "behavior": {
        "value": "20",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Probability_of_contacting_a_potential_adopter",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Potential_Adopters]/[Total_population]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "type": "LINK",
      "from": "Adoption_from_advertising",
      "to": "adoption_rate"
    },
    {
      "type": "LINK",
      "from": "Adoption_from_word_of_mouth",
      "to": "adoption_rate"
    },
    {
      "type": "LINK",
      "from": "Potential_Adopters",
      "to": "adoption_rate"
    },
    {
      "type": "LINK",
      "from": "Adopters",
      "to": "adoption_rate"
    },
    {
      "type": "LINK",
      "from": "Potential_Adopters",
      "to": "Adoption_from_advertising"
    },
    {
      "type": "LINK",
      "from": "Advertising_effectiveness_per_year",
      "to": "Adoption_from_advertising"
    },
    {
      "type": "LINK",
      "from": "Adopters",
      "to": "Adoption_from_word_of_mouth"
    },
    {
      "type": "LINK",
      "from": "Adoption_fraction_per_contact",
      "to": "Adoption_from_word_of_mouth"
    },
    {
      "type": "LINK",
      "from": "Contact_rate_per_year",
      "to": "Adoption_from_word_of_mouth"
    },
    {
      "type": "LINK",
      "from": "Probability_of_contacting_a_potential_adopter",
      "to": "Adoption_from_word_of_mouth"
    },
    {
      "type": "LINK",
      "from": "Potential_Adopters",
      "to": "Probability_of_contacting_a_potential_adopter"
    },
    {
      "type": "LINK",
      "from": "Total_population",
      "to": "Probability_of_contacting_a_potential_adopter"
    }
  ],
  "engine_settings": []
}
