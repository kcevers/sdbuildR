{
  "engine": "SIMULATION_PACKAGE",
  "name": "Rotating Pendulum",
  "simulation": {
    "version": "36",
    "time_length": "10",
    "time_start": "0",
    "time_step": "0.01",
    "time_units": "SECONDS",
    "algorithm": "RK1"
  },
  "elements": [
    {
      "name": "Angular_Velocity",
      "type": "STOCK",
      "behavior": {
        "initial_value": "10",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "angular_acceleration",
      "type": "FLOW",
      "from": null,
      "to": "Angular_Velocity",
      "behavior": {
        "value": "[mass_acceleration]/[pendulum_radius]",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Angle",
      "type": "STOCK",
      "behavior": {
        "initial_value": "1.52",
        "description": "Can vary between 0 and pi/2",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "angle_rate_of_change",
      "type": "FLOW",
      "from": null,
      "to": "Angle",
      "behavior": {
        "value": "[Angular_Velocity]",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "damping_force",
      "type": "VARIABLE",
      "behavior": {
        "value": "[damping_constant]*[Angular_Velocity]*[pendulum_radius]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "damping_constant",
      "type": "VARIABLE",
      "behavior": {
        "value": "1",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "pendulum_radius",
      "type": "VARIABLE",
      "behavior": {
        "value": "1",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "mass_acceleration",
      "type": "VARIABLE",
      "behavior": {
        "value": "-([acceleration_force]+[damping_force])/[pendulum_mass]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "acceleration_force",
      "type": "VARIABLE",
      "behavior": {
        "value": "[pendulum_mass]*[gravitation_constant]*Sin([Angle])",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "pendulum_mass",
      "type": "VARIABLE",
      "behavior": {
        "value": "1",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "gravitation_constant",
      "type": "VARIABLE",
      "behavior": {
        "value": "9.81",
        "description": "kg per second",
        "units": "Unitless"
      }
    },
    {
      "type": "LINK",
      "from": "pendulum_radius",
      "to": "angular_acceleration"
    },
    {
      "type": "LINK",
      "from": "mass_acceleration",
      "to": "angular_acceleration"
    },
    {
      "type": "LINK",
      "from": "Angular_Velocity",
      "to": "angular_acceleration"
    },
    {
      "type": "LINK",
      "from": "Angular_Velocity",
      "to": "angle_rate_of_change"
    },
    {
      "type": "LINK",
      "from": "Angle",
      "to": "angle_rate_of_change"
    },
    {
      "type": "LINK",
      "from": "Angular_Velocity",
      "to": "damping_force"
    },
    {
      "type": "LINK",
      "from": "damping_constant",
      "to": "damping_force"
    },
    {
      "type": "LINK",
      "from": "pendulum_radius",
      "to": "damping_force"
    },
    {
      "type": "LINK",
      "from": "damping_force",
      "to": "mass_acceleration"
    },
    {
      "type": "LINK",
      "from": "acceleration_force",
      "to": "mass_acceleration"
    },
    {
      "type": "LINK",
      "from": "pendulum_mass",
      "to": "mass_acceleration"
    },
    {
      "type": "LINK",
      "from": "Angle",
      "to": "acceleration_force"
    },
    {
      "type": "LINK",
      "from": "pendulum_mass",
      "to": "acceleration_force"
    },
    {
      "type": "LINK",
      "from": "gravitation_constant",
      "to": "acceleration_force"
    }
  ],
  "engine_settings": []
}
