{
  "engine": "SIMULATION_PACKAGE",
  "name": "Fern Population Model",
  "simulation": {
    "version": "36",
    "time_length": "120",
    "time_start": "0",
    "time_step": "0.1",
    "time_units": "MONTHS",
    "algorithm": "RK1"
  },
  "elements": [
    {
      "name": "Available_Sunlight",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Sunlight]-(0.95*[Ferns]/[Relative_Habitat_Size])",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Ferns",
      "type": "STOCK",
      "behavior": {
        "initial_value": "1",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Fern_Growth",
      "type": "FLOW",
      "from": null,
      "to": "Ferns",
      "behavior": {
        "value": "[Fertility]*2*[Available_Sunlight]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Fern_Deaths",
      "type": "FLOW",
      "from": "Ferns",
      "to": null,
      "behavior": {
        "value": "[Predation]+[Mortality]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Fern_Migration",
      "type": "FLOW",
      "from": null,
      "to": "Ferns",
      "behavior": {
        "value": "IfThenElse([Migration_Chance]=True, Rand(0, 5), 0)",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Migration_Chance",
      "type": "VARIABLE",
      "behavior": {
        "value": "RandBoolean(0.05)",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Comments",
      "type": "STOCK",
      "behavior": {
        "initial_value": "##Assuming the ecosystem is the area of Burnaby, i.e. 17,000 football fields\n##Assuming the number of blades of grass that can fit in a football field, and that 2000 blades of grass comprise one fern, and that there are 17k football fields worth of land, means there can be 3.3 billion ferns\n\n\n",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Fertility",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.30*[Ferns]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Mortality",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.1*[Ferns]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Predation",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.1*[Ferns]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Sunlight",
      "type": "VARIABLE",
      "behavior": {
        "value": "Seasonal(8)*0.2+0.75",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Relative_Habitat_Size",
      "type": "VARIABLE",
      "behavior": {
        "value": "331361.2800",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "type": "LINK",
      "from": "Ferns",
      "to": "Available_Sunlight"
    },
    {
      "type": "LINK",
      "from": "Sunlight",
      "to": "Available_Sunlight"
    },
    {
      "type": "LINK",
      "from": "Relative_Habitat_Size",
      "to": "Available_Sunlight"
    },
    {
      "type": "LINK",
      "from": "Available_Sunlight",
      "to": "Fern_Growth"
    },
    {
      "type": "LINK",
      "from": "Fertility",
      "to": "Fern_Growth"
    },
    {
      "type": "LINK",
      "from": "Ferns",
      "to": "Fern_Growth"
    },
    {
      "type": "LINK",
      "from": "Mortality",
      "to": "Fern_Deaths"
    },
    {
      "type": "LINK",
      "from": "Predation",
      "to": "Fern_Deaths"
    },
    {
      "type": "LINK",
      "from": "Ferns",
      "to": "Fern_Deaths"
    },
    {
      "type": "LINK",
      "from": "Migration_Chance",
      "to": "Fern_Migration"
    },
    {
      "type": "LINK",
      "from": "Ferns",
      "to": "Fern_Migration"
    },
    {
      "type": "LINK",
      "from": "Ferns",
      "to": "Fertility"
    },
    {
      "type": "LINK",
      "from": "Ferns",
      "to": "Mortality"
    },
    {
      "type": "LINK",
      "from": "Ferns",
      "to": "Predation"
    }
  ],
  "engine_settings": []
}
