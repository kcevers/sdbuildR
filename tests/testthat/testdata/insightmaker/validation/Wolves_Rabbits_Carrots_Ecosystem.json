{
  "engine": "SIMULATION_PACKAGE",
  "name": "Wolves_Rabbits_Carrots Ecosystem",
  "simulation": {
    "version": "38",
    "time_length": "2000",
    "time_start": "0",
    "time_step": "1",
    "time_units": "DAYS",
    "algorithm": "RK4"
