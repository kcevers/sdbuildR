    {
      "name": "Rabbit_Births",
      "type": "FLOW",
      "from": null,
      "to": "Rabbits",
      "behavior": {
        "value": "If ([Carrots]/[Rabbits])<[Minimal_Carrot_Ration] Then\n  0\nElse\n  [Rabbits]*[Rabbit_Birth_Rate]\nEnd If",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Rabbit_Deaths",
      "type": "FLOW",
      "from": "Rabbits",
      "to": null,
      "behavior": {
        "value": "If ([Carrots]/[Rabbits])<[Minimal_Carrot_Ration] Then\n  0.2*[Rabbits]\nElse\n  0.0001*[Rabbits]*[Wolves]\nEnd If",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
