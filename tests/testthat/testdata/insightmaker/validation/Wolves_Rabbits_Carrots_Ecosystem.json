  "elements": [
    {
      "name": "Carrot_Growth_Rate",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.2+0.2*Sin(2*pi*Days()/180)",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Carrots",
      "type": "STOCK",
      "behavior": {
        "initial_value": "2000",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Growth",
      "type": "FLOW",
      "from": null,
      "to": "Carrots",
      "behavior": {
        "value": "[Carrot_Growth_Rate]*[Carrots]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Carrot_Deaths",
      "type": "FLOW",
