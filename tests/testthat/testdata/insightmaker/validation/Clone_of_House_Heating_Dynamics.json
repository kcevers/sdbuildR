{
  "engine": "SIMULATION_PACKAGE",
  "name": "Clone of House Heating Dynamics",
  "simulation": {
    "version": "37",
    "time_length": "1",
    "time_start": "0",
    "time_step": "0.02",
    "time_units": "YEARS",
    "algorithm": "RK1"
  },
  "elements": [
    {
      "name": "house_length_east_west",
      "type": "VARIABLE",
      "behavior": {
        "value": "12.5",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "house_width_north_south",
      "type": "VARIABLE",
      "behavior": {
        "value": "8",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "height_to_eaves",
      "type": "VARIABLE",
      "behavior": {
        "value": "3",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "floor_area",
      "type": "VARIABLE",
      "behavior": {
        "value": "[house_width_north_south]*[house_length_east_west]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "window_area",
      "type": "VARIABLE",
      "behavior": {
        "value": "[window_fraction_other_walls]*(2*[house_width_north_south]*[height_to_eaves]+[house_length_east_west]*[height_to_eaves])",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "area_of_outer_walls",
      "type": "VARIABLE",
      "behavior": {
        "value": "2*[house_width_north_south]*[height_to_eaves]+2*[house_length_east_west]*[height_to_eaves]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "ceiling_area",
      "type": "VARIABLE",
      "behavior": {
        "value": "[floor_area]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "window_fraction_other_walls",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.2",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "window_fraction_south_wall",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.8",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "area_of_south_windows",
      "type": "VARIABLE",
      "behavior": {
        "value": "[window_fraction_south_wall]*[house_length_east_west]*[height_to_eaves]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "specific_heat_transfer_upper_part_of_house",
      "type": "VARIABLE",
      "behavior": {
        "value": "([k_insulation_parameter_walls]*([area_of_outer_walls]-([window_area]+[area_of_south_windows])))+[k_insulation_parameter_roof]*[ceiling_area]+[k_insulation_parameter_windows]*([window_area]+[area_of_south_windows])",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "specific_heat_transfer_to_ground",
      "type": "VARIABLE",
      "behavior": {
        "value": "[k_insulation_parameter_floor]*[floor_area]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "k_insulation_parameter_windows",
      "type": "VARIABLE",
      "behavior": {
        "value": "1.6",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "k_insulation_parameter_floor",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.2",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "k_insulation_parameter_walls",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.15",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "k_insulation_parameter_roof",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.2",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "ground_temperature",
      "type": "VARIABLE",
      "behavior": {
        "value": "9",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "heat_loss_to_ground",
      "type": "VARIABLE",
      "behavior": {
        "value": "[specific_heat_transfer_to_ground]*([desired_room_temperature]-[ground_temperature])",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "desired_room_temperature",
      "type": "VARIABLE",
      "behavior": {
        "value": "19",
        "description": "Default is 19",
        "units": "Unitless"
      }
    },
    {
      "name": "heating_limit_temperature",
      "type": "VARIABLE",
      "behavior": {
        "value": "[desired_room_temperature]+([heat_loss_to_ground]-[solar_heating_gain])/[specific_heat_transfer_upper_part_of_house]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "collector_efficiency_south_windows",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.8",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "solar_heating_gain",
      "type": "VARIABLE",
      "behavior": {
        "value": "[area_of_south_windows]*[collector_efficiency_south_windows]*[insolation_on_vertical_wall]/100",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "heating_power_demand",
      "type": "VARIABLE",
      "behavior": {
        "value": "IfThenElse([heating_limit_temperature]<=[outdoor_temperature],0, [specific_heat_transfer_upper_part_of_house]*([desired_room_temperature]-[outdoor_temperature])+[heat_loss_to_ground]-[solar_heating_gain])",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "furnace_power_demand",
      "type": "VARIABLE",
      "behavior": {
        "value": "[heating_power_demand]/[efficiency_of_furnace]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "heating_parameter",
      "type": "VARIABLE",
      "behavior": {
        "value": "IfThenElse([furnace_power_demand]>0, 1, 0)",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "efficiency_of_furnace",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.85",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "fuel_oil_consumption",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "heating_degree_days",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "heating_period",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "heating_operational",
      "type": "FLOW",
      "from": null,
      "to": "heating_period",
      "behavior": {
        "value": "[heating_parameter]*[days_per_year]",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "energy_content_of_fuel",
      "type": "VARIABLE",
      "behavior": {
        "value": "11900",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "hours_per_year",
      "type": "VARIABLE",
      "behavior": {
        "value": "8760",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "burn_rate",
      "type": "FLOW",
      "from": null,
      "to": "fuel_oil_consumption",
      "behavior": {
        "value": "([hours_per_year]/[energy_content_of_fuel])*[furnace_power_demand]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "heating",
      "type": "FLOW",
      "from": null,
      "to": "heating_degree_days",
      "behavior": {
        "value": "([heating_limit_temperature]-[outdoor_temperature])*[days_per_year]*[heating_parameter]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "days_per_year",
      "type": "VARIABLE",
      "behavior": {
        "value": "365",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "insolation_on_vertical_wall",
      "type": "CONVERTER",
      "behavior": {
        "input": "ELEMENT",
        "input_element": "months",
        "interpolation": "LINEAR",
        "data": [
            [0, 102],
            [0.5, 101],
            [1.5, 111],
            [2.5, 105],
            [3.5, 79],
            [4.5, 45],
            [5.5, 38],
            [6.5, 48],
            [7.5, 69],
            [8.5, 99],
            [9.5, 102],
            [10.5, 106],
            [11.5, 104],
            [12, 102]
          ],
        "units": "Unitless"
      }
    },
    {
      "name": "outdoor_temperature",
      "type": "CONVERTER",
      "behavior": {
        "input": "ELEMENT",
        "input_element": "months",
        "interpolation": "LINEAR",
        "data": [
            [0, 17],
            [0.5, 17.8],
            [1.5, 17.3],
            [2.5, 14.2],
            [3.5, 9.1],
            [4.5, 4.9],
            [5.5, 1.5],
            [6.5, 0],
            [7.5, 0.8],
            [8.5, 4.6],
            [9.5, 8.8],
            [10.5, 13.2],
            [11.5, 16.4],
            [12, 17]
          ],
        "units": "Unitless"
      }
    },
    {
      "name": "months",
      "type": "VARIABLE",
      "behavior": {
        "value": "([time_1]-Floor([time_1]))*[months_per_year]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "month",
      "type": "VARIABLE",
      "behavior": {
        "value": "[time_1]*[months_per_year]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "months_per_year",
      "type": "VARIABLE",
      "behavior": {
        "value": "12",
        "description": "",
        "units": "Unitless"
      }
    },
    {
