{
  "engine": "SIMULATION_PACKAGE",
  "name": "Wind Resistance Model",
  "simulation": {
    "version": "36",
    "time_length": "20",
    "time_start": "0",
    "time_step": "0.01",
    "time_units": "SECONDS",
    "algorithm": "RK1"
  },
  "elements": [
    {
      "name": "Displacement",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "",
        "units": "meters"
      }
    },
    {
      "name": "Velocity_Flow",
      "type": "FLOW",
      "from": null,
      "to": "Displacement",
      "behavior": {
        "value": "[Velocity_Stock]",
        "description": "",
        "units": "meters/second",
        "non_negative": false
      }
    },
    {
      "name": "Velocity_Stock",
      "type": "STOCK",
      "behavior": {
        "initial_value": "60",
        "description": "",
        "units": "meters/second"
      }
    },
    {
      "name": "Acceleration",
      "type": "FLOW",
      "from": null,
      "to": "Velocity_Stock",
      "behavior": {
        "value": "[Net_Force]/[Mass]",
        "description": "",
        "units": "meters/second^2",
        "non_negative": false
      }
    },
    {
      "name": "Mass",
      "type": "VARIABLE",
      "behavior": {
        "value": ".2",
        "description": "",
        "units": "kilograms"
      }
    },
    {
      "name": "Net_Force",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Gravity_Force]+[Drag_Force]",
        "description": "",
        "units": "Newtons"
      }
    },
    {
      "name": "Gravity_Force",
      "type": "VARIABLE",
      "behavior": {
        "value": "-[Mass]*[Acceleration_of_Gravity]",
        "description": "",
        "units": "Newtons"
      }
    },
    {
      "name": "Acceleration_of_Gravity",
      "type": "VARIABLE",
      "behavior": {
        "value": "9.81",
        "description": "",
        "units": "meters/seconds^2"
      }
    },
    {
      "name": "Drag_Force",
      "type": "VARIABLE",
      "behavior": {
        "value": "-Sign([Velocity_Stock])*.5*[Air_Density]*[Velocity_Stock]^2*[Frontal_Area]*[Coefficient_of_Drag]",
        "description": "",
        "units": "Newtons"
      }
    },
    {
      "name": "Air_Density",
      "type": "VARIABLE",
      "behavior": {
        "value": "1.2",
        "description": "",
        "units": "kilograms/meters^3"
      }
    },
    {
      "name": "Coefficient_of_Drag",
      "type": "VARIABLE",
      "behavior": {
        "value": ".79",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Frontal_Area",
      "type": "VARIABLE",
      "behavior": {
        "value": ".00201",
        "description": "",
        "units": "meters^2"
      }
    },
    {
      "type": "LINK",
      "from": "Velocity_Stock",
      "to": "Velocity_Flow"
    },
    {
      "type": "LINK",
      "from": "Displacement",
      "to": "Velocity_Flow"
    },
    {
      "type": "LINK",
      "from": "Mass",
      "to": "Acceleration"
    },
    {
      "type": "LINK",
      "from": "Net_Force",
      "to": "Acceleration"
    },
    {
      "type": "LINK",
      "from": "Velocity_Stock",
      "to": "Acceleration"
    },
    {
      "type": "LINK",
      "from": "Gravity_Force",
      "to": "Net_Force"
    },
    {
      "type": "LINK",
      "from": "Drag_Force",
      "to": "Net_Force"
    },
    {
      "type": "LINK",
      "from": "Mass",
      "to": "Gravity_Force"
    },
    {
      "type": "LINK",
      "from": "Acceleration_of_Gravity",
      "to": "Gravity_Force"
    },
    {
      "type": "LINK",
      "from": "Velocity_Stock",
      "to": "Drag_Force"
    },
    {
      "type": "LINK",
      "from": "Velocity_Stock",
      "to": "Drag_Force"
    },
    {
      "type": "LINK",
      "from": "Air_Density",
      "to": "Drag_Force"
    },
    {
      "type": "LINK",
      "from": "Coefficient_of_Drag",
      "to": "Drag_Force"
    },
    {
      "type": "LINK",
      "from": "Frontal_Area",
      "to": "Drag_Force"
    }
  ],
  "engine_settings": []
