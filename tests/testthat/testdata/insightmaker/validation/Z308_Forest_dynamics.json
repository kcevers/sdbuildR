{
  "engine": "SIMULATION_PACKAGE",
  "name": "Systems Zoo Z308: Forest dynamics",
  "simulation": {
    "version": "38",
    "time_length": "150",
    "time_start": "0",
    "time_step": "0.1",
    "time_units": "YEARS",
    "algorithm": "RK4"
  },
  "elements": [
    {
      "name": "leaf_biomass",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0.2",
        "description": "UNITS: t ODM/ha",
        "units": "Unitless"
      }
    },
    {
      "name": "wood_biomass",
      "type": "STOCK",
      "behavior": {
        "initial_value": "1",
        "description": "UNITS: t ODM/ha",
        "units": "Unitless"
      }
    },
    {
      "name": "canopy_production",
      "type": "VARIABLE",
      "behavior": {
        "value": "[leaf_proportional_energy_utilization]*[leaf_biomass]*[specific_canopy_production]*(1-[production_decrease])",
        "description": "UNITS: t ODM/(ha*Year)",
        "units": "Unitless"
      }
    },
    {
      "name": "leaf_loss",
      "type": "FLOW",
      "from": "leaf_biomass",
      "to": null,
      "behavior": {
        "value": "[leaf_loss_rate]*[leaf_biomass]",
        "description": "UNITS: t ODM/(ha*Year)",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "wood_increment",
      "type": "FLOW",
      "from": null,
      "to": "wood_biomass",
      "behavior": {
        "value": "[canopy_production]-[actual_leaf_flushing]-[stem_respiration]",
        "description": "UNITS: t ODM/(ha*Year)",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "deadwood_loss",
      "type": "FLOW",
      "from": "wood_biomass",
      "to": null,
      "behavior": {
        "value": "[deadwood_loss_rate]*[wood_biomass]",
        "description": "UNITS: t ODM/(ha*Year)",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "leaf_loss_rate",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.2",
        "description": "UNITS: 1/Year",
        "units": "Unitless"
      }
    },
    {
      "name": "leaf_goal",
      "type": "VARIABLE",
      "behavior": {
        "value": "[max_leaf_flushing_rate]*[leaf_biomass]*(1-[leaf_biomass]/[leaf_volume_capacity])",
        "description": "UNITS: t ODM/(ha*Year)",
        "units": "Unitless"
      }
    },
    {
      "name": "assimilate_surplus",
      "type": "VARIABLE",
      "behavior": {
        "value": "[canopy_production]-[leaf_goal]-[stem_respiration]",
        "description": "UNITS: t ODM/(ha*Year)",
        "units": "Unitless"
      }
    },
    {
      "name": "actual_leaf_flushing",
      "type": "FLOW",
      "from": null,
      "to": "leaf_biomass",
      "behavior": {
        "value": "If [assimilate_surplus]>0 Then\n  [leaf_goal]\nElse If ([canopy_production]-[stem_respiration]>0) Then\n  [canopy_production]-[stem_respiration]\nElse\n  0\nEnd If",
        "description": "UNITS: t ODM/(ha*Year)",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "stem_respiration",
      "type": "VARIABLE",
      "behavior": {
        "value": "[stem_proportional_respiration_rate]*[wood_biomass]",
        "description": "UNITS: t ODM/(ha*Year)",
        "units": "Unitless"
      }
    },
    {
      "name": "net_wood_increment",
      "type": "VARIABLE",
      "behavior": {
        "value": "[wood_increment]-[deadwood_loss]",
        "description": "UNITS: t ODM/(ha*Year)",
        "units": "Unitless"
      }
    },
    {
      "name": "production_decrease",
      "type": "VARIABLE",
      "behavior": {
        "value": "STEP([initial_year_of_environmental_stress], [production_loss_from_pollutants]/100)",
        "description": "unitless",
        "units": "Unitless"
      }
    },
    {
      "name": "specific_canopy_production",
      "type": "VARIABLE",
      "behavior": {
        "value": "6",
        "description": "UNITS: t ODM/(t ODM*Year) canopy production per year relative to leaf mass ",
        "units": "Unitless"
      }
    },
    {
      "name": "leaf_proportional_energy_utilization",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.5",
        "description": "unitless",
        "units": "Unitless"
      }
    },
    {
      "name": "initial_year_of_environmental_stress",
      "type": "VARIABLE",
      "behavior": {
        "value": "100",
        "description": "UNITS: Year",
        "units": "Unitless"
      }
    },
    {
      "name": "production_loss_from_pollutants",
      "type": "VARIABLE",
      "behavior": {
        "value": "0",
        "description": "Unitless",
        "units": "Unitless"
      }
    },
    {
      "name": "deadwood_loss_rate",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.01",
        "description": "UNITS: 1/Year",
        "units": "Unitless"
      }
    },
    {
      "name": "stem_proportional_respiration_rate",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.03",
        "description": "UNITS: 1/Year",
        "units": "Unitless"
      }
    },
    {
      "name": "max_leaf_flushing_rate",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.5",
        "description": "UNITS: 1/Year",
        "units": "Unitless"
      }
    },
    {
      "name": "leaf_volume_capacity",
      "type": "VARIABLE",
      "behavior": {
        "value": "10",
        "description": "UNITS: t ODM/ha",
        "units": "Unitless"
      }
    },
    {
      "type": "LINK",
      "from": "leaf_biomass",
      "to": "canopy_production"
    },
    {
      "type": "LINK",
      "from": "production_decrease",
      "to": "canopy_production"
    },
    {
      "type": "LINK",
      "from": "specific_canopy_production",
      "to": "canopy_production"
    },
    {
      "type": "LINK",
      "from": "leaf_proportional_energy_utilization",
      "to": "canopy_production"
    },
    {
      "type": "LINK",
      "from": "leaf_biomass",
      "to": "leaf_loss"
    },
    {
      "type": "LINK",
      "from": "leaf_loss_rate",
      "to": "leaf_loss"
    },
    {
      "type": "LINK",
      "from": "leaf_biomass",
      "to": "leaf_loss"
    },
    {
      "type": "LINK",
      "from": "canopy_production",
      "to": "wood_increment"
    },
    {
      "type": "LINK",
      "from": "actual_leaf_flushing",
      "to": "wood_increment"
    },
    {
      "type": "LINK",
      "from": "stem_respiration",
      "to": "wood_increment"
    },
    {
      "type": "LINK",
      "from": "wood_biomass",
      "to": "wood_increment"
    },
    {
      "type": "LINK",
      "from": "wood_biomass",
      "to": "deadwood_loss"
    },
    {
      "type": "LINK",
      "from": "deadwood_loss_rate",
      "to": "deadwood_loss"
    },
    {
      "type": "LINK",
      "from": "wood_biomass",
      "to": "deadwood_loss"
    },
    {
      "type": "LINK",
      "from": "leaf_biomass",
      "to": "leaf_goal"
    },
    {
      "type": "LINK",
      "from": "leaf_biomass",
      "to": "leaf_goal"
    },
    {
      "type": "LINK",
      "from": "max_leaf_flushing_rate",
      "to": "leaf_goal"
    },
    {
      "type": "LINK",
      "from": "leaf_volume_capacity",
      "to": "leaf_goal"
    },
    {
      "type": "LINK",
      "from": "canopy_production",
      "to": "assimilate_surplus"
    },
    {
      "type": "LINK",
      "from": "leaf_goal",
      "to": "assimilate_surplus"
    },
    {
      "type": "LINK",
      "from": "stem_respiration",
      "to": "assimilate_surplus"
    },
    {
      "type": "LINK",
      "from": "canopy_production",
      "to": "actual_leaf_flushing"
    },
    {
      "type": "LINK",
      "from": "canopy_production",
      "to": "actual_leaf_flushing"
    },
    {
      "type": "LINK",
      "from": "leaf_goal",
      "to": "actual_leaf_flushing"
    },
    {
      "type": "LINK",
      "from": "assimilate_surplus",
      "to": "actual_leaf_flushing"
    },
    {
      "type": "LINK",
      "from": "stem_respiration",
      "to": "actual_leaf_flushing"
    },
    {
      "type": "LINK",
      "from": "stem_respiration",
      "to": "actual_leaf_flushing"
    },
    {
      "type": "LINK",
      "from": "leaf_biomass",
      "to": "actual_leaf_flushing"
    },
    {
      "type": "LINK",
      "from": "wood_biomass",
      "to": "stem_respiration"
    },
    {
      "type": "LINK",
      "from": "stem_proportional_respiration_rate",
      "to": "stem_respiration"
    },
    {
      "type": "LINK",
      "from": "wood_increment",
      "to": "net_wood_increment"
    },
    {
      "type": "LINK",
      "from": "deadwood_loss",
      "to": "net_wood_increment"
    },
    {
      "type": "LINK",
      "from": "initial_year_of_environmental_stress",
      "to": "production_decrease"
    },
    {
      "type": "LINK",
      "from": "production_loss_from_pollutants",
      "to": "production_decrease"
    }
  ],
  "engine_settings": []
}
