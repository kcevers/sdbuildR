{
  "engine": "SIMULATION_PACKAGE",
  "name": "Viral Growth",
  "simulation": {
    "version": "36",
    "time_length": "12",
    "time_start": "0",
    "time_step": "1",
    "time_units": "MONTHS",
    "algorithm": "RK1"
  },
  "elements": [
    {
      "name": "Users",
      "type": "STOCK",
      "behavior": {
        "initial_value": "[Initial_Users]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "App_Store",
      "type": "FLOW",
      "from": null,
      "to": "Users",
      "behavior": {
        "value": "24000",
        "description": "Users gained per month from the App Store.",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Initial_Users",
      "type": "VARIABLE",
      "behavior": {
        "value": "70000",
        "description": "Initial number of users due to publicity.",
        "units": "Unitless"
      }
    },
    {
      "name": "Direct_Traffic",
      "type": "FLOW",
      "from": null,
      "to": "Users",
      "behavior": {
        "value": "10000",
        "description": "Users gained per month in direct traffic.",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "User_Loss",
      "type": "FLOW",
      "from": "Users",
      "to": null,
      "behavior": {
        "value": "[Lost_Rate]*[Users]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Lost_Rate",
      "type": "VARIABLE",
      "behavior": {
        "value": ".15",
        "description": "Propotion of users lost per month.",
        "units": "Unitless"
      }
    },
    {
      "name": "Viral_Growth_Rate",
      "type": "VARIABLE",
      "behavior": {
        "value": ".2",
        "description": "Viral growth factor per month.",
        "units": "Unitless"
      }
    },
    {
      "name": "Viral_Growth",
      "type": "FLOW",
      "from": null,
      "to": "Users",
      "behavior": {
        "value": "[Viral_Growth_Rate]*([Direct_Traffic]+[App_Store]+ifthenelse(months=0,[Initial_Users],0))",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "type": "LINK",
      "from": "Initial_Users",
      "to": "Users"
    },
    {
      "type": "LINK",
      "from": "Users",
      "to": "App_Store"
    },
    {
      "type": "LINK",
      "from": "Users",
      "to": "Direct_Traffic"
    },
    {
      "type": "LINK",
      "from": "Users",
      "to": "User_Loss"
    },
    {
      "type": "LINK",
      "from": "Lost_Rate",
      "to": "User_Loss"
    },
    {
      "type": "LINK",
      "from": "Users",
      "to": "User_Loss"
    },
    {
      "type": "LINK",
      "from": "App_Store",
      "to": "Viral_Growth"
    },
    {
      "type": "LINK",
      "from": "Initial_Users",
      "to": "Viral_Growth"
    },
    {
      "type": "LINK",
      "from": "Direct_Traffic",
      "to": "Viral_Growth"
    },
    {
      "type": "LINK",
      "from": "Viral_Growth_Rate",
      "to": "Viral_Growth"
    },
    {
      "type": "LINK",
      "from": "Users",
      "to": "Viral_Growth"
    }
  ],
  "engine_settings": []
}
