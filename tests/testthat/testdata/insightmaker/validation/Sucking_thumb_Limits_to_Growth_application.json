{
  "engine": "SIMULATION_PACKAGE",
  "name": "Sucking thumb - Limits to Growth application",
  "simulation": {
    "version": "34",
    "time_length": "15",
    "time_start": "0",
    "time_step": "1",
    "time_units": "DAYS",
    "algorithm": "RK1"
  },
  "elements": [
    {
      "name": "factor",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.5",
        "description": "Seldom is the action simply equal to the value of results. This is a factor to interact with results to define action.",
        "units": "Unitless"
      }
    },
    {
      "name": "Overall_satisfaction",
      "type": "STOCK",
      "behavior": {
        "initial_value": "1",
        "description": "The accumulated result of action.",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Sucking_thumb",
      "type": "FLOW",
      "from": null,
      "to": "Overall_satisfaction",
      "behavior": {
        "value": "[Overall_satisfaction] * [factor]",
        "description": "Action arising from the interaction of results and factor adds to results.",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Parents_show_dis_aproval",
      "type": "FLOW",
      "from": "Overall_satisfaction",
      "to": null,
      "behavior": {
        "value": "IfThenElse([Overall_satisfaction] > [limiting_factor], ([Overall_satisfaction] - [limiting_factor]) * [slowing_factor], 0)",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "limiting_factor",
      "type": "VARIABLE",
      "behavior": {
        "value": "5",
        "description": "The value at which results begin to become limited.",
        "units": "Unitless"
      }
    },
    {
      "name": "slowing_factor",
      "type": "VARIABLE",
      "behavior": {
        "value": "1",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "type": "LINK",
      "from": "factor",
      "to": "Sucking_thumb"
    },
    {
      "type": "LINK",
      "from": "Overall_satisfaction",
      "to": "Sucking_thumb"
    },
    {
      "type": "LINK",
      "from": "Overall_satisfaction",
      "to": "Sucking_thumb"
    },
    {
      "type": "LINK",
      "from": "Overall_satisfaction",
      "to": "Parents_show_dis_aproval"
    },
    {
      "type": "LINK",
      "from": "Overall_satisfaction",
      "to": "Parents_show_dis_aproval"
    },
    {
      "type": "LINK",
      "from": "limiting_factor",
      "to": "Parents_show_dis_aproval"
    },
    {
      "type": "LINK",
      "from": "limiting_factor",
      "to": "Parents_show_dis_aproval"
    },
    {
      "type": "LINK",
      "from": "slowing_factor",
      "to": "Parents_show_dis_aproval"
    },
    {
      "type": "LINK",
      "from": "Overall_satisfaction",
      "to": "Parents_show_dis_aproval"
    }
  ],
  "engine_settings": []
}
