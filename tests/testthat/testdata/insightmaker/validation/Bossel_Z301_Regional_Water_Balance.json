{
  "engine": "SIMULATION_PACKAGE",
  "name": "Bossel: Z301 Regional Water Balance",
  "simulation": {
    "version": "37",
    "time_length": "100",
    "time_start": "0",
    "time_step": "0.03125",
    "time_units": "HOURS",
    "algorithm": "RK1"
  },
  "elements": [
    {
      "name": "soil_water_inflow",
      "type": "FLOW",
      "from": null,
      "to": "soil_water",
      "behavior": {
        "value": "[rainfall_rate]*(1-[FOREST_FRACTION]*[interception_function])",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "RAINFALL_DURATION_HOURS",
      "type": "VARIABLE",
      "behavior": {
        "value": "30",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "soil_water",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "FOREST_FRACTION",
      "type": "VARIABLE",
      "behavior": {
        "value": "0",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "evapo_transpiration",
      "type": "VARIABLE",
      "behavior": {
        "value": "[relative_water_saturation]*(37/1000)*(1+(35/37)*SIN(6.28*((Hours()/8760)+(25/52)-0.25)))*12/8760\n",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "DEPTH_OF_WATER_STORING_SOIL_LAYER",
      "type": "VARIABLE",
      "behavior": {
        "value": "30",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "water_saturation_capacity",
      "type": "VARIABLE",
      "behavior": {
        "value": "[DEPTH_OF_WATER_STORING_SOIL_LAYER]/1000*0.3",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "relative_water_saturation",
      "type": "VARIABLE",
      "behavior": {
        "value": "IfThenElse(([soil_water]/[water_saturation_capacity_of_soil])>1,1,([soil_water]/[water_saturation_capacity_of_soil]))\n\n\n",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "RAINFALL_AMOUNT_m",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.05",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "rainfall_rate",
      "type": "VARIABLE",
      "behavior": {
        "value": "IfThenElse(hours()>=0 and hours()<[RAINFALL_DURATION_HOURS], [RAINFALL_AMOUNT_m]/[RAINFALL_DURATION_HOURS], 0)",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "interception_function",
      "type": "CONVERTER",
      "behavior": {
        "input": "ELEMENT",
        "input_element": "rainfall_rate",
        "interpolation": "LINEAR",
        "data": [
            [0, 1],
            [0.5, 0.5],
            [10, 0.05],
            [20, 0.02]
          ],
        "units": "Unitless"
      }
    },
    {
      "name": "soil_water_outflow",
      "type": "FLOW",
      "from": "soil_water",
      "to": null,
      "behavior": {
        "value": "[evapo_transpiration]+[runoff_surplus]+[percolation_rate]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "ground_water",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "water_saturation_capacity_of_soil",
      "type": "VARIABLE",
      "behavior": {
        "value": "(1/1000)+[water_saturation_capacity]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "percolation_rate",
      "type": "VARIABLE",
      "behavior": {
        "value": "IfThenElse(([soil_water]-(0.2*([DEPTH_OF_WATER_STORING_SOIL_LAYER]/1000)))>0, (([soil_water]-(0.2*([DEPTH_OF_WATER_STORING_SOIL_LAYER]/1000)))/[soil_water])*0.0001, 0)",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "WATERSHED_AREA",
      "type": "VARIABLE",
      "behavior": {
        "value": "1e+08",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "ground_water_inflow",
      "type": "FLOW",
      "from": null,
      "to": "ground_water",
      "behavior": {
        "value": "[WATERSHED_AREA]*[percolation_rate]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "runoff_surplus",
      "type": "VARIABLE",
      "behavior": {
        "value": "IfThenElse(([soil_water]-[water_saturation_capacity_of_soil])>0, (([soil_water]-[water_saturation_capacity_of_soil])/[soil_water])*100*0.0001, 0)",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Flooding",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "run_off",
      "type": "FLOW",
      "from": null,
      "to": "Flooding",
      "behavior": {
        "value": "([creek_runoff]*(.5))+[reservoir_outflow]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "soil_water_runoff",
      "type": "VARIABLE",
      "behavior": {
        "value": "[runoff_surplus]*[WATERSHED_AREA]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "ground_water_outflow",
      "type": "FLOW",
      "from": "ground_water",
      "to": null,
      "behavior": {
        "value": "IfThenElse(((((-(-10))*(([average_runoff]*1/(0.01*1e+06))-1))+([ground_water]/(1e+07*0.15)))-(-10))>0, (((((-(-10))*(([average_runoff]*1/(0.01*1e+06))-1))+([ground_water]/(1e+07*0.15)))-(-10))/(-(-10)))*0.01*1e+06, 0)",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "average_runoff",
      "type": "VARIABLE",
      "behavior": {
        "value": "((876/8760)/1000)*(0.2)*[WATERSHED_AREA]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "creek_runoff",
      "type": "VARIABLE",
      "behavior": {
        "value": "[soil_water_runoff]+[ground_water_outflow]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "water_in_reservoirs",
      "type": "STOCK",
      "behavior": {
        "initial_value": "[DAM_CAPACITY]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "reservoir_outflow",
      "type": "FLOW",
      "from": "water_in_reservoirs",
      "to": null,
      "behavior": {
        "value": "IFTHENELSE([DAM_CAPACITY]>0, ([runoff_volume]*[water_in_reservoirs]/[DAM_CAPACITY]), 0)",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "reservoir_inflow",
      "type": "FLOW",
      "from": null,
      "to": "water_in_reservoirs",
      "behavior": {
        "value": "(0.5)*[creek_runoff]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "runoff_volume",
      "type": "VARIABLE",
      "behavior": {
        "value": "IFTHENELSE(([water_in_reservoirs]-[DAM_CAPACITY])>0, (0.5)*[average_runoff]*20, (0.5)*[average_runoff]*2)",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "DAM_CAPACITY",
      "type": "VARIABLE",
      "behavior": {
        "value": "2000000",
        "description": "",
        "units": "Unitless"
      }
    },
