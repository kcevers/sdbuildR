      "name": "start_test",
      "type": "FLOW",
      "from": "I_Needs_assessment_Healthcare_planning",
      "to": "Healthcare_investigation",
      "behavior": {
        "value": "[I_Needs_assessment_Healthcare_planning]*[investigate_fraction]/([initial_assess_time]+[wait_for_tests])",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "No_need_for_further_activities",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Clinical_Process_Outcome_Evaluation",
