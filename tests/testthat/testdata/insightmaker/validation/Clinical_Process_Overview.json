{
  "engine": "SIMULATION_PACKAGE",
  "name": "Clinical Process Overview",
  "simulation": {
    "version": "38",
    "time_length": "100",
    "time_start": "0",
    "time_step": "0.25",
    "time_units": "DAYS",
    "algorithm": "RK1"
  },
