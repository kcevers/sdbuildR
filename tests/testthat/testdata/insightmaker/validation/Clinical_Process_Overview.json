      "from": "Demand_for_initial_contact",
      "to": "Initial_Contact",
      "behavior": {
        "value": "[Demand_for_initial_contact]*[present_fraction]/[time_to_present]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "see",
      "type": "FLOW",
      "from": "Initial_Contact",
      "to": "I_Needs_assessment_Healthcare_planning",
      "behavior": {
        "value": "[Initial_Contact]/[wait_time]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
