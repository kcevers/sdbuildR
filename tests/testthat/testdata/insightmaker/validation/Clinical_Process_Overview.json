        "value": "[I_Needs_assessment_Healthcare_planning]*(1-[investigate_fraction])/[initial_assess_time]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "to",
      "type": "FLOW",
      "from": "No_need_for_further_activities",
      "to": "Clinical_Process_Outcome_Evaluation",
      "behavior": {
        "value": "0",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Dx_Health_condition",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "investigated and usually diagnosed but could be misdiagnosed",
        "units": "Unitless"
      }
    },
    {
      "name": "end_test",
      "type": "FLOW",
      "from": "Healthcare_investigation",
