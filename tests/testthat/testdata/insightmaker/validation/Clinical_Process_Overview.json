        "value": "[C_Needs_assessment_Healthcare_planning]*[treat_fraction]/([time_to_assess_needs_of_condition]+[wait_for_treatment])",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Rx_Health_condition",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "treated",
        "units": "Unitless"
