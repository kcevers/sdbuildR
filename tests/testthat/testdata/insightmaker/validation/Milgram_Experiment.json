{
  "engine": "SIMULATION_PACKAGE",
  "name": "Milgram Experiment",
  "simulation": {
    "version": "36",
    "time_length": "50",
    "time_start": "0",
    "time_step": "0.25",
    "time_units": "MINUTES",
    "algorithm": "RK1"
  },
  "elements": [
    {
      "name": "Subject_Anxiety",
      "type": "STOCK",
      "behavior": {
        "initial_value": "5",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "anxiety_increase",
      "type": "FLOW",
      "from": null,
      "to": "Subject_Anxiety",
      "behavior": {
        "value": "[normal_anxiety_growth_fraction]*[Subject_Anxiety]*[anxiety_from_authority_insistence]*[anxiety_from_victim_resistance]*[anxiety_from_volts]*[Subject_Termination_Multiplier]*[Empathy]",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "anxiety_decrease",
      "type": "FLOW",
      "from": "Subject_Anxiety",
      "to": null,
      "behavior": {
        "value": "[Subject_Anxiety]*[Subject_Termination_Multiplier]*[Anxiety_decrease_coefficient]",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Maximum_Acceptable_Punishment",
      "type": "STOCK",
      "behavior": {
        "initial_value": "150",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "increase",
      "type": "FLOW",
      "from": null,
      "to": "Maximum_Acceptable_Punishment",
      "behavior": {
        "value": "[Insistence_by_authority]*[Subject_Termination_Multiplier]/[Moral_Resistance]",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Total_Punishment_Delivered",
      "type": "STOCK",
      "behavior": {
        "initial_value": "0",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "decrease",
      "type": "FLOW",
      "from": "Maximum_Acceptable_Punishment",
      "to": null,
      "behavior": {
        "value": "[effect_of_victim_resistance_on_decreasing_max]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Subject_Termination_Multiplier",
      "type": "VARIABLE",
      "behavior": {
        "value": "[anxiety_termination]*[experimenter_termination]*[subject_termination]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "anxiety_termination",
      "type": "VARIABLE",
      "behavior": {
        "value": "IfThenElse([maximum_anxiety]-[Subject_Anxiety]>0, 1, 0)",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "experimenter_termination",
      "type": "VARIABLE",
      "behavior": {
        "value": "IfThenElse([maximum_volts]-[Total_Punishment_Delivered]>0, 1, 0)",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "subject_termination",
      "type": "VARIABLE",
      "behavior": {
        "value": "IfThenElse([willingness_to_continue]>0, 1, 0)",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "maximum_anxiety",
      "type": "VARIABLE",
      "behavior": {
        "value": "50",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "maximum_volts",
      "type": "VARIABLE",
      "behavior": {
        "value": "11475",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "willingness_to_continue",
      "type": "CONVERTER",
      "behavior": {
        "input": "ELEMENT",
        "input_element": "gap",
        "interpolation": "LINEAR",
        "data": [
            [-25, -0.1],
            [0, 0],
            [25, 0.05],
            [50, 0.2],
            [75, 0.65],
            [100, 0.75],
            [125, 0.9],
            [150, 0.95],
            [175, 0.98],
            [200, 1]
          ],
        "units": "Unitless"
      }
    },
    {
      "name": "volts",
      "type": "VARIABLE",
      "behavior": {
        "value": "(Minutes()+1)*15",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "punishment",
      "type": "FLOW",
      "from": null,
      "to": "Total_Punishment_Delivered",
      "behavior": {
        "value": "[volts_delivery]/[Time_to_deliver]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Time_to_deliver",
      "type": "VARIABLE",
      "behavior": {
        "value": "1",
        "description": "",
        "units": "Unitless"
      }
