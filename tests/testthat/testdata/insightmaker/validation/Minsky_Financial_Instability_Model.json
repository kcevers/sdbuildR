{
  "engine": "SIMULATION_PACKAGE",
  "name": "Minsky Financial Instability Model",
  "simulation": {
    "version": "36",
    "time_length": "200",
    "time_start": "0",
    "time_step": "0.5",
    "time_units": "YEARS",
    "algorithm": "RK1"
  },
  "elements": [
    {
      "name": "Capital",
      "type": "STOCK",
      "behavior": {
        "initial_value": "300",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "investment",
      "type": "FLOW",
      "from": null,
      "to": "Capital",
      "behavior": {
        "value": "[Profit]*[fraction_invested]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "fraction_invested",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.99",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Wage_share",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Wages]/[Output]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Output",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Capital]/[accelerator]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Profit",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Pre_Tax_Profit]+[Govt_Subsidy]-[Tax_on_Profits]-[Debt_interest]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "accelerator",
      "type": "VARIABLE",
      "behavior": {
        "value": "3",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Employment",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Output]/[Productivity]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Wages",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Wage_rate]*[Employment]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Employment_rate",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Employment]/([Working_population]*[Participation_rate])",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Working_population",
      "type": "STOCK",
      "behavior": {
        "initial_value": "200",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "pop_increase",
      "type": "FLOW",
      "from": null,
      "to": "Working_population",
      "behavior": {
        "value": "[Working_population]*[growth_rate]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "growth_rate",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.02",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Participation_rate",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.9",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Wage_change",
      "type": "CONVERTER",
      "behavior": {
        "input": "ELEMENT",
        "input_element": "Employment_rate",
        "interpolation": "LINEAR",
        "data": [
            [0.78, -0.04],
            [0.797, -0.02],
            [0.815, -0.035],
            [0.832, -0.035],
            [0.85, -0.0313],
            [0.867, -0.0163],
            [0.885, 0.0025],
            [0.902, 0.0212],
            [0.92, 0.0362],
            [0.937, 0.0587],
            [0.955, 0.0737],
            [0.972, 0.085],
            [0.99, 0.0962]
          ],
        "units": "Unitless"
      }
    },
    {
      "name": "Wage_rate",
      "type": "STOCK",
      "behavior": {
        "initial_value": "1",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "wage_increase",
      "type": "FLOW",
      "from": null,
      "to": "Wage_rate",
      "behavior": {
        "value": "[Wage_rate]*[Wage_change]",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Productivity",
      "type": "STOCK",
      "behavior": {
        "initial_value": "1",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "productivity_increase",
      "type": "FLOW",
      "from": null,
      "to": "Productivity",
      "behavior": {
        "value": "[Productivity]*[productivity_growth_rate]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "productivity_growth_rate",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.03",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "depreciation",
      "type": "FLOW",
      "from": "Capital",
      "to": null,
      "behavior": {
        "value": "[Capital]*[Depreciation_rate]",
        "description": "",
        "units": "Unitless",
        "non_negative": true
      }
    },
    {
      "name": "Depreciation_rate",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.05",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Debt",
      "type": "STOCK",
      "behavior": {
        "initial_value": "300",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Debt_interest",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Debt]*[Debt_interest_rate]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "change_in_debt",
      "type": "FLOW",
      "from": null,
      "to": "Debt",
      "behavior": {
        "value": "[Debt]*[Debt_interest_rate]+[debt_principal_increase]",
        "description": "",
        "units": "Unitless",
        "non_negative": false
      }
    },
    {
      "name": "Debt_interest_rate",
      "type": "VARIABLE",
      "behavior": {
        "value": "-0.1",
        "description": "default is 0.05",
        "units": "Unitless"
      }
    },
    {
      "name": "debt_principal_increase",
      "type": "VARIABLE",
      "behavior": {
        "value": "[investment]-[Profit]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Pre_Tax_Profit",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Output]-[Wages]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Tax_on_Wages",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Wages]*[Income_Tax_rate]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Income_Tax_rate",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.3",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Tax_Revenue",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Tax_on_Wages]+[Tax_on_Profits]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Tax_on_Profits",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Pre_Tax_Profit]*[Company_Tax_rate]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Company_Tax_rate",
      "type": "VARIABLE",
      "behavior": {
        "value": "0.3",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Govt_Subsidy",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Tax_Revenue]*[Fraction_on_subsidy]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Fraction_on_subsidy",
      "type": "VARIABLE",
      "behavior": {
        "value": "1",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "name": "Debt_Fraction",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Debt]/[Output]",
        "description": "",
        "units": "Unitless"
      }
    },
    {
      "type": "LINK",
      "from": "fraction_invested",
      "to": "investment"
    },
    {
      "type": "LINK",
      "from": "Profit",
      "to": "investment"
    },
    {
      "type": "LINK",
      "from": "Capital",
      "to": "investment"
    },
