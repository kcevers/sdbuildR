{
  "engine": "SIMULATION_PACKAGE",
  "name": "E coli life cycle model",
  "simulation": {
    "version": "36",
    "time_length": "50",
    "time_start": "0",
    "time_step": "0.2",
    "time_units": "HOURS",
    "algorithm": "RK1"
  },
  "elements": [
    {
      "name": "E__coli",
      "type": "STOCK",
      "behavior": {
        "initial_value": "10",
        "description": "The <i>E. coli<\/i> growth simulation begins with one viable cell.  The exponential growth model assumes no limits for the moment.",
        "units": "Cells"
      }
    },
    {
      "name": "dividing",
      "type": "FLOW",
      "from": null,
      "to": "E__coli",
      "behavior": {
        "value": "Step({8 Hours}, ([E__coli]*[Doubling_rate]))",
        "description": "<i>E. coli<\/i> has a \"lag\" period of about eight hours before it begins dividing.  We introduce a step function so that there will be no growth (dividing) for the first eight hours.",
        "units": "Cells/Hours",
        "non_negative": true
      }
    },
    {
      "name": "Doubling_rate",
      "type": "VARIABLE",
      "behavior": {
        "value": "3",
        "description": "<i>âE. coli<\/i> divides once about every 20 minutes.  Each divide doubles the number of cells.  Yes, it multiplies by dividing, which is what makes math so confusing at times!",
        "units": "1/Hours"
      }
    },
    {
      "name": "dying",
      "type": "FLOW",
      "from": "E__coli",
      "to": null,
      "behavior": {
        "value": "Step({16 Hours}, ([E__coli]*[Death_fraction]))",
        "description": "",
        "units": "Cells/Hours",
        "non_negative": true
      }
    },
    {
      "name": "Death_fraction",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Normal_death_fraction]*[Effect_of_Petri_dish_on_death_fraction]",
        "description": "",
        "units": "1/Hours"
      }
    },
    {
      "name": "Normal_death_fraction",
      "type": "VARIABLE",
      "behavior": {
        "value": "20406122",
        "description": "",
        "units": "1/Hours"
      }
    },
    {
      "name": "Petri_dish",
      "type": "STOCK",
      "behavior": {
        "initial_value": "1000000000",
        "description": "",
        "units": "Units"
      }
    },
    {
      "name": "degradation",
      "type": "FLOW",
      "from": "Petri_dish",
      "to": null,
      "behavior": {
        "value": "([E__coli]*[Degradation_per_E__coli])",
        "description": "Loss of hospitable environment in the Petri dish",
        "units": "Units/Hours",
        "non_negative": true
      }
    },
    {
      "name": "Effect_of_Petri_dish_on_death_fraction",
      "type": "CONVERTER",
      "behavior": {
        "input": "ELEMENT",
        "input_element": "Petri_dish_filling",
        "interpolation": "LINEAR",
        "data": [
            [0, 10],
            [0.1, 7.798],
            [0.2, 6.055],
            [0.3, 4.954],
            [0.4, 3.578],
            [0.5, 3.028],
            [0.6, 2.661],
            [0.7, 2.202],
            [0.8, 1.927],
            [0.9, 1.56],
            [1, 1]
          ],
        "units": "Unitless"
      }
    },
    {
      "name": "Normal_Petri_dish_capacity",
      "type": "VARIABLE",
      "behavior": {
        "value": "1000000000",
        "description": "capacity of the petri dish",
        "units": "Units"
      }
    },
    {
      "name": "Effect_of_Petri_dish_on_degradation_per_E__coli",
      "type": "CONVERTER",
      "behavior": {
        "input": "ELEMENT",
        "input_element": "Petri_dish_filling",
        "interpolation": "LINEAR",
        "data": [
            [0, 0],
            [0.1, 0.365],
            [0.2, 0.6],
            [0.3, 0.75],
            [0.4, 0.855],
            [0.5, 0.91],
            [0.55, 0.94],
            [0.6, 0.955],
            [0.65, 0.97],
            [0.7, 0.98],
            [0.75, 0.99],
            [0.8, 0.99],
            [0.85, 0.99],
            [0.9, 1],
            [0.95, 1],
            [1, 1]
          ],
        "units": "Unitless"
      }
    },
    {
      "name": "Degradation_per_E__coli",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Normal_degradation_per_E__coli]*[Effect_of_Petri_dish_on_degradation_per_E__coli]",
        "description": "",
        "units": "(Units/Cells)/Hours"
      }
    },
    {
      "name": "Normal_degradation_per_E__coli",
      "type": "VARIABLE",
      "behavior": {
        "value": "1",
        "description": "Size units?",
        "units": "(Units/Cells)/Hours"
      }
    },
    {
      "name": "Petri_dish_filling",
      "type": "VARIABLE",
      "behavior": {
        "value": "[Petri_dish]/[Normal_Petri_dish_capacity]",
        "description": "This variable represents how full the Petri dish is at any point in the growth cycle.",
        "units": "Unitless"
      }
    },
    {
      "type": "LINK",
      "from": "E__coli",
      "to": "dividing"
    },
    {
      "type": "LINK",
      "from": "Doubling_rate",
      "to": "dividing"
    },
    {
      "type": "LINK",
      "from": "E__coli",
      "to": "dividing"
    },
    {
      "type": "LINK",
      "from": "E__coli",
      "to": "dying"
    },
    {
      "type": "LINK",
      "from": "Death_fraction",
      "to": "dying"
    },
    {
      "type": "LINK",
      "from": "E__coli",
      "to": "dying"
    },
    {
      "type": "LINK",
      "from": "Normal_death_fraction",
      "to": "Death_fraction"
    },
    {
      "type": "LINK",
      "from": "Effect_of_Petri_dish_on_death_fraction",
      "to": "Death_fraction"
    },
    {
      "type": "LINK",
      "from": "E__coli",
      "to": "degradation"
    },
    {
      "type": "LINK",
      "from": "Degradation_per_E__coli",
      "to": "degradation"
    },
    {
      "type": "LINK",
      "from": "Petri_dish",
      "to": "degradation"
    },
    {
      "type": "LINK",
      "from": "Effect_of_Petri_dish_on_degradation_per_E__coli",
      "to": "Degradation_per_E__coli"
    },
    {
      "type": "LINK",
      "from": "Normal_degradation_per_E__coli",
      "to": "Degradation_per_E__coli"
    },
    {
      "type": "LINK",
      "from": "Petri_dish",
      "to": "Petri_dish_filling"
    },
    {
      "type": "LINK",
      "from": "Normal_Petri_dish_capacity",
      "to": "Petri_dish_filling"
    }
  ],
  "engine_settings": []
}
